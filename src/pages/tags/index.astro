---
import { TAGS_CONFIG } from '~/config'
import { getAllTags } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'

const { title, introduce } = TAGS_CONFIG
const tagsMap = await getAllTags()

const sortedTags = Object.entries(tagsMap)
  .map(([tag, count]) => ({ name: tag, count }))
  .sort((a, b) => {
    if (b.count !== a.count) return b.count - a.count
    return a.name.localeCompare(b.name)
  })
---

<Layout title={title} description={TAGS_CONFIG.description}>
  <div class="antfu-page">
    <h1>{title}</h1>
    <p class="antfu-desc">{introduce}</p>

    <ul class="antfu-list">
      {sortedTags.map((tag) => (
        <li>
          <a href={`/tags/${encodeURIComponent(tag.name)}`} class="antfu-list-link">
            <span>{tag.name}</span>
            <span class="antfu-count">{tag.count}</span>
          </a>
        </li>
      ))}
    </ul>

    {sortedTags.length === 0 && <p>暂无标签。</p>}
  </div>
</Layout>

<style>
  .antfu-page { max-width: var(--layout-width); margin-inline: auto; padding: 4rem 1rem 2rem; }
  .antfu-page h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5em; }
  .antfu-desc { opacity: var(--opacity-muted); margin: 0 0 2rem; }
  .antfu-list { list-style: none; padding: 0; margin: 0; }
  .antfu-list li { margin: 0; }
  .antfu-list-link {
    display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem;
    padding: 0.35em 0; text-decoration: none; color: var(--theme-text); transition: opacity 200ms ease;
  }
  .antfu-list-link:hover { opacity: var(--opacity-secondary); }
  .antfu-count { flex-shrink: 0; font-size: 0.8125rem; opacity: var(--opacity-muted); }
</style>
