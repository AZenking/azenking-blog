---
import { TAGS_CONFIG } from '~/config'
import Layout from '~/layouts/Layout.astro'
import { getAllPosts } from '~/lib/data'
import { getAllTags } from '~/lib/data'

const { title, description, introduce } = TAGS_CONFIG

const [tagsMap, posts] = await Promise.all([getAllTags(), getAllPosts()])

const sortedTags = Object.entries(tagsMap)
  .map(([tag, count]) => ({
    name: tag,
    count,
  }))
  .sort((a, b) => {
    if (b.count !== a.count) return b.count - a.count
    return a.name.localeCompare(b.name)
  })

const totalTaggedMentions = sortedTags.reduce((sum, tag) => sum + tag.count, 0)
const maxCount = sortedTags.length > 0 ? Math.max(...sortedTags.map((tag) => tag.count)) : 1
---

<Layout {title} {description}>
  <div class="px-6 py-12 sm:px-8 sm:py-14">
    <section class="mx-auto max-w-3xl">
      <p class="text-sm uppercase tracking-[0.16em] text-muted-foreground">Topic Index</p>
      <h1 class="mt-3 font-sans text-[clamp(2.1rem,5vw,3.4rem)] font-semibold tracking-tight text-foreground">{title}</h1>
      <p class="mt-5 max-w-[62ch] text-base leading-8 text-muted-foreground">{introduce}</p>
      <div class="mt-8 grid grid-cols-1 gap-3 text-sm text-muted-foreground sm:grid-cols-3">
        <div class="rounded-2xl border border-border/55 bg-background/72 px-4 py-3">
          <p class="text-xs uppercase tracking-[0.12em]">Tags</p>
          <p class="mt-1 text-xl font-medium tracking-tight text-foreground">{sortedTags.length}</p>
        </div>
        <div class="rounded-2xl border border-border/55 bg-background/72 px-4 py-3">
          <p class="text-xs uppercase tracking-[0.12em]">Posts</p>
          <p class="mt-1 text-xl font-medium tracking-tight text-foreground">{posts.length}</p>
        </div>
        <div class="rounded-2xl border border-border/55 bg-background/72 px-4 py-3">
          <p class="text-xs uppercase tracking-[0.12em]">Mentions</p>
          <p class="mt-1 text-xl font-medium tracking-tight text-foreground">{totalTaggedMentions}</p>
        </div>
      </div>
    </section>

    {sortedTags.length > 0 ? (
      <section class="mx-auto mt-12 max-w-5xl">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:gap-6">
          {
            sortedTags.map((tag) => {
              const widthPercent = Math.max((tag.count / maxCount) * 100, 8)
              const mentionPercent = Math.round((tag.count / totalTaggedMentions) * 100)

              return (
                <a
                  href={`/tags/${encodeURIComponent(tag.name)}`}
                  class="group rounded-3xl border border-border/55 bg-background/72 p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-border/90 hover:bg-background/92 sm:p-6"
                >
                  <div class="flex items-start justify-between gap-3">
                    <h2 class="min-w-0 truncate font-sans text-xl font-medium tracking-tight text-foreground">#{tag.name}</h2>
                    <span class="shrink-0 text-sm text-muted-foreground">{tag.count} posts</span>
                  </div>

                  <div class="mt-5 h-px bg-border/55" />

                  <div class="mt-4 flex items-center justify-between text-xs uppercase tracking-[0.12em] text-muted-foreground">
                    <span>Coverage</span>
                    <span>{mentionPercent}%</span>
                  </div>

                  <div class="mt-2 h-1.5 overflow-hidden rounded-full bg-muted/45">
                    <span class="block h-full rounded-full bg-foreground/66 transition-all duration-300 group-hover:bg-foreground/80" style={`width: ${widthPercent}%`} />
                  </div>
                </a>
              )
            })
          }
        </div>
      </section>
    ) : (
      <section class="mx-auto mt-14 max-w-3xl rounded-3xl border border-border/55 bg-background/72 px-6 py-14 text-center sm:px-8">
        <span class="icon-[ph--tag] mx-auto block size-10 text-muted-foreground/55" />
        <p class="mt-4 text-sm text-muted-foreground">No tags available yet.</p>
      </section>
    )}
  </div>
</Layout>
