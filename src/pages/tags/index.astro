---
import { TAGS_CONFIG } from '~/config'
import { getAllPosts, getAllTags } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'

const { title, description, introduce } = TAGS_CONFIG

const [tagsMap, posts] = await Promise.all([getAllTags(), getAllPosts()])

const sortedTags = Object.entries(tagsMap)
  .map(([tag, count]) => ({
    name: tag,
    count,
  }))
  .sort((a, b) => {
    if (b.count !== a.count) return b.count - a.count
    return a.name.localeCompare(b.name)
  })

const totalTaggedMentions = sortedTags.reduce((sum, tag) => sum + tag.count, 0)
const featuredTags = sortedTags.slice(0, 10)
---

<Layout {title} {description} fullWidth>
  <div class="min-h-screen bg-[#f4f4f0] text-black dark:bg-[#242423] dark:text-white">
    <section class="w-full px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
      <div class="border-b border-black pb-8 dark:border-white/35">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Topic Index</p>
            <h1 class="mt-4 text-[clamp(2.5rem,6vw,4.75rem)] leading-[1.02] tracking-[-0.06em]">{title}</h1>
            <p class="mt-5 max-w-[48rem] text-base leading-8 text-black/66 sm:text-lg dark:text-white/66">{introduce}</p>
          </div>

          <div class="grid w-full max-w-xl grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Tags</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{sortedTags.length}</p>
            </div>
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Posts</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{posts.length}</p>
            </div>
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Mentions</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{totalTaggedMentions}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        {featuredTags.map((tag) => (
          <a
            href={`/tags/${encodeURIComponent(tag.name)}`}
            class="inline-flex items-center gap-2 rounded-sm border border-black bg-white px-3 py-2 text-sm text-black no-underline transition-colors hover:bg-black hover:text-white dark:border-white/35 dark:bg-black dark:text-white dark:hover:bg-white dark:hover:text-black"
          >
            <span>{tag.name}</span>
            <span class="text-black/50 dark:text-white/50">({tag.count})</span>
          </a>
        ))}
      </div>

      <section class="mt-14 border-t border-black pt-8 dark:border-white/35">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Archive</p>
            <h2 class="mt-3 text-[clamp(1.9rem,4vw,3.15rem)] leading-[1.04] tracking-[-0.05em]">All Topics</h2>
          </div>
          <p class="max-w-xl text-sm leading-7 text-black/62 dark:text-white/62">
            Topic cards sized by usage count, using the same bordered editorial system as the rest of the site.
          </p>
        </div>

        {sortedTags.length > 0 ? (
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {sortedTags.map((tag) => {
              const mentionPercent = totalTaggedMentions > 0 ? Math.round((tag.count / totalTaggedMentions) * 100) : 0

              return (
                <a
                  href={`/tags/${encodeURIComponent(tag.name)}`}
                  class="group rounded-lg border border-black bg-white p-6 text-black no-underline transition-all duration-200 ease-out hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[3px_3px_0_0_#000] dark:border-white/35 dark:bg-black dark:text-white dark:hover:shadow-[3px_3px_0_0_rgba(255,255,255,0.35)]"
                >
                  <div class="flex items-start justify-between gap-4">
                    <h3 class="min-w-0 truncate text-2xl leading-tight tracking-[-0.04em]">#{tag.name}</h3>
                    <span class="inline-flex rounded-sm border border-black px-2 py-1 text-xs uppercase tracking-[0.1em] dark:border-white/35">
                      {tag.count}
                    </span>
                  </div>

                  <div class="mt-8 flex items-end justify-between gap-4">
                    <div>
                      <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Coverage</p>
                      <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{mentionPercent}%</p>
                    </div>
                    <span class="inline-flex size-10 items-center justify-center rounded-md border border-black transition-all duration-200 group-hover:-translate-x-px group-hover:-translate-y-px group-hover:shadow-[2px_2px_0_0_#000] dark:border-white/35 dark:group-hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]">
                      →
                    </span>
                  </div>
                </a>
              )
            })}
          </div>
        ) : (
          <p class="text-sm text-black/56 dark:text-white/56">No tags available yet.</p>
        )}
      </section>
    </section>
  </div>
</Layout>
