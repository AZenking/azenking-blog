---
import { TAGS_CONFIG } from '~/config'
import { getAllTags } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'

const { title, introduce } = TAGS_CONFIG
const tagsMap = await getAllTags()

const sortedTags = Object.entries(tagsMap)
  .map(([tag, count]) => ({ name: tag, count }))
  .sort((a, b) => {
    if (b.count !== a.count) return b.count - a.count
    return a.name.localeCompare(b.name)
  })
---

<Layout title={title} description={TAGS_CONFIG.description} fullWidth>
  <div class="magi-page">
    <h1>{title}</h1>
    <p class="magi-desc">{introduce}</p>

    <ul class="magi-list">
      {sortedTags.map((tag) => (
        <li>
          <a href={`/tags/${encodeURIComponent(tag.name)}`} class="magi-list-link">
            <span>{tag.name}</span>
            <span class="magi-count">{tag.count}</span>
          </a>
        </li>
      ))}
    </ul>

    {sortedTags.length === 0 && <p>暂无标签。</p>}
  </div>
</Layout>

<style>
  .magi-page {
    width: 100%;
    margin-inline: auto;
    padding-block: clamp(3.5rem, 8vw, 6rem) 3rem;
    padding-inline: max(1.25rem, calc((100% - var(--content-width)) / 2));
    color: var(--article-ink);
    background:
      linear-gradient(180deg, rgb(128 122 113 / 0.035), transparent 18rem),
      var(--article-paper);
  }

  .magi-page h1 {
    margin: 0 0 0.4em;
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .magi-desc {
    margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
    color: var(--article-soft);
    font-family: var(--font-editorial);
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.5;
    text-wrap: balance;
  }

  .magi-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem 1.5rem;
  }
  .magi-list li { margin: 0; }

  .magi-list-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(1.2rem, 2.2vw, 1.4rem);
    font-weight: 500;
    line-height: 1.3;
    text-wrap: balance;
    text-decoration: none;
    transition: opacity 200ms ease;
  }

  .magi-list-link:hover { opacity: 1; color: var(--brand); }

  .magi-count {
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    opacity: 0.85;
  }

  @media (max-width: 760px) {
    .magi-page { padding-top: 3rem; }
  }
</style>
