---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import Pagination from '~/components/base/Pagination.astro'
import { POSTS_CONFIG } from '~/config'
import { getAllPosts, getAllTags } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const [allPosts, tagsMap] = await Promise.all([getAllPosts(), getAllTags()])

  return Object.keys(tagsMap)
    .map((tag) => {
      const tagPosts = allPosts.filter((post) => post.data.tags?.includes(tag))
      return paginate(tagPosts, {
        params: { tag },
        props: { tag },
        pageSize: POSTS_CONFIG.tagsPageConfig.size,
      })
    })
    .flat()
}

interface Props {
  page: Page<CollectionEntry<'posts'>>
  tag: string
}

const { page, tag } = Astro.props
const description = `Ethan Young 博客中与 #${tag} 相关的文章归档，共 ${page.total} 篇。`
const encodedTag = encodeURIComponent(tag)
const allTags = await getAllTags()

const relatedTags = Object.entries(allTags)
  .filter(([name]) => name !== tag)
  .sort(([, countA], [, countB]) => countB - countA)
  .slice(0, 8)

const postsByYear = new Map<number, CollectionEntry<'posts'>[]>()
for (const post of page.data) {
  const year = (post.data.updatedDate ?? post.data.pubDate).getFullYear()
  if (!postsByYear.has(year)) postsByYear.set(year, [])
  postsByYear.get(year)!.push(post)
}
const yearGroups = [...postsByYear.entries()].sort(([a], [b]) => b - a)
---

<Layout title={`#${tag}`} description={description}>
  <div class="antfu-page">
    <a href="/tags" class="antfu-back">← Back to tags</a>
    <h1>#{tag}</h1>
    <p class="antfu-desc">这个主题下共有 {page.total} 篇文章。</p>

    <nav class="antfu-tags">
      <span class="is-active">#{tag} ({page.total})</span>
      {relatedTags.map(([name, count]) => (
        <a href={`/tags/${encodeURIComponent(name)}`}>#{name} ({count})</a>
      ))}
    </nav>

    {yearGroups.map(([year, posts]) => (
      <section class="antfu-year-group">
        <h2 class="antfu-year">{year}</h2>
        <ul class="antfu-list">
          {posts.map((post) => (
            <li>
              <a href={`/posts/${post.id}`} class="antfu-list-link">
                <span>{post.data.title}</span>
                <time>{formatDate(post.data.updatedDate ?? post.data.pubDate, 'short')}</time>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    {page.data.length === 0 && <p>这个标签下暂无文章。</p>}

    <Pagination {page} baseUrl={`/tags/${encodedTag}`} />
  </div>
</Layout>

<style>
  .antfu-page { max-width: var(--layout-width); margin-inline: auto; padding: 4rem 1rem 2rem; }
  .antfu-back { display: inline-block; margin-bottom: 1rem; font-size: 0.9375rem; text-decoration: none; opacity: var(--opacity-muted); transition: opacity 200ms ease; }
  .antfu-back:hover { opacity: 1; }
  .antfu-page h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5em; }
  .antfu-desc { opacity: var(--opacity-muted); margin: 0 0 2rem; }
  .antfu-tags { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2.5rem; }
  .antfu-tags a, .antfu-tags span { text-decoration: none; opacity: var(--opacity-muted); transition: opacity 200ms ease; }
  .antfu-tags a:hover { opacity: 1; }
  .antfu-tags .is-active { opacity: 1; font-weight: 600; }
  .antfu-year-group { margin-bottom: 2.5rem; }
  .antfu-year { font-size: 0.9375rem; font-weight: 600; opacity: var(--opacity-muted); margin: 0 0 0.75rem; }
  .antfu-list { list-style: none; padding: 0; margin: 0; }
  .antfu-list li { margin: 0; }
  .antfu-list-link {
    display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem;
    padding: 0.35em 0; text-decoration: none; color: var(--theme-text); transition: opacity 200ms ease;
  }
  .antfu-list-link:hover { opacity: var(--opacity-secondary); }
  .antfu-list-link time { flex-shrink: 0; font-size: 0.8125rem; opacity: var(--opacity-muted); }
</style>
