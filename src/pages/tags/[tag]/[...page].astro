---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import LqipImage from '~/components/base/LqipImage.astro'
import Pagination from '~/components/base/Pagination.astro'
import { POSTS_CONFIG } from '~/config'
import { getAllPosts, getAllTags } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const [allPosts, tagsMap] = await Promise.all([getAllPosts(), getAllTags()])

  return Object.keys(tagsMap)
    .map((tag) => {
      const tagPosts = allPosts.filter((post) => post.data.tags?.includes(tag))
      return paginate(tagPosts, {
        params: { tag },
        props: { tag },
        pageSize: POSTS_CONFIG.tagsPageConfig.size,
      })
    })
    .flat()
}

interface Props {
  page: Page<CollectionEntry<'posts'>>
  tag: string
}

const { page, tag } = Astro.props
const description = `Ethan Young 博客中与 #${tag} 相关的文章归档，共 ${page.total} 篇，涵盖技术实践、工具配置和个人记录。`
const encodedTag = encodeURIComponent(tag)
const allTags = await getAllTags()

const relatedTags = Object.entries(allTags)
  .filter(([name]) => name !== tag)
  .sort(([, countA], [, countB]) => countB - countA)
  .slice(0, 8)

const isFirstPage = page.currentPage === 1
const featuredPost = isFirstPage ? page.data[0] : null
const streamPosts = isFirstPage ? page.data.slice(1) : page.data
const tileAccents = ['verge-accent-mint', 'verge-accent-purple', 'verge-accent-yellow', 'verge-accent-pink', 'verge-accent-orange']
---

<Layout title={`#${tag}`} {description} fullWidth>
  <div class="verge-shell">
    <section class="mx-auto w-full max-w-[88rem] px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
      <div class="border-b border-white/28 pb-5">
        <a href="/tags" class="verge-pill">← 返回标签</a>

        <div class="mt-5 grid gap-5 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
          <div>
            <p class="verge-kicker">标签归档</p>
            <h1 class="verge-display mt-4 text-[clamp(4.4rem,14vw,12rem)] leading-[0.76] tracking-normal">#{tag}</h1>
            <p class="verge-copy mt-4 max-w-[52rem] text-base sm:text-lg">
              这个主题下共有 {page.total} 篇文章。
            </p>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <div class="verge-stat">
              <p class="verge-kicker text-white/48">文章</p>
              <p class="mt-2 text-3xl leading-none tracking-normal text-white">{page.total}</p>
            </div>
            <div class="verge-stat">
              <p class="verge-kicker text-white/48">相关</p>
              <p class="mt-2 text-3xl leading-none tracking-normal text-white">{relatedTags.length}</p>
            </div>
            <div class="verge-stat">
              <p class="verge-kicker text-white/48">页码</p>
              <p class="mt-2 text-3xl leading-none tracking-normal text-white">{page.currentPage}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 border-b border-white/28 py-5">
        <span class="verge-pill verge-pill-active">#{tag}</span>
        {relatedTags.map(([name, count]) => (
          <a href={`/tags/${encodeURIComponent(name)}`} class="verge-pill">
            <span>{name}</span>
            <span class="opacity-60">({count})</span>
          </a>
        ))}
      </div>

      {featuredPost && (
        <section class="border-b border-white/28 py-5">
          <a href={`/posts/${featuredPost.id}`} class="verge-card-link overflow-hidden p-0">
            <article class="grid h-full lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1fr)]">
              <div class="min-h-72 border-b border-white/28 bg-[var(--theme-surface-soft)] lg:border-b-0 lg:border-r">
                {featuredPost.data.cover ? (
                  <LqipImage
                    src={featuredPost.data.cover}
                    alt={featuredPost.data.title}
                    width={980}
                    height={720}
                    loading="eager"
                    decoding="async"
                    format="webp"
                    class="h-full min-h-72 w-full object-cover"
                  />
                ) : (
                  <div class="verge-accent-purple flex h-full min-h-72 items-end p-6">
                    <span class="font-display text-[clamp(4rem,10vw,8rem)] leading-[0.8] tracking-normal">#</span>
                  </div>
                )}
              </div>

              <div class="flex min-h-full flex-col justify-between gap-10 p-5 sm:p-7">
                <div>
                  <p class="verge-kicker text-white/52">#{tag} 精选</p>
                  <h2 class="verge-heading mt-4 text-[clamp(2.15rem,4.8vw,5rem)] leading-[0.92]">{featuredPost.data.title}</h2>
                  {featuredPost.data.description && (
                    <p class="verge-copy mt-5 text-base sm:text-lg">{featuredPost.data.description}</p>
                  )}
                </div>

                <p class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-white/58">
                  {formatDate(featuredPost.data.updatedDate ?? featuredPost.data.pubDate, 'short')}
                </p>
              </div>
            </article>
          </a>
        </section>
      )}

      <section class="py-6">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="verge-kicker">时间线</p>
            <h2 class="mt-2 text-[clamp(2rem,4.6vw,4.2rem)] font-black leading-[0.9] tracking-normal text-white">主题记录</h2>
          </div>
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-white/48">
            本页 {streamPosts.length} 篇
          </p>
        </div>

        {streamPosts.length > 0 ? (
          <div class="relative grid gap-4 md:pl-16 md:before:absolute md:before:left-7 md:before:top-2 md:before:h-[calc(100%-0.5rem)] md:before:w-px md:before:bg-white/25">
            {streamPosts.map((post, index) => (
              <article class="relative grid gap-3 md:grid-cols-[7rem_minmax(0,1fr)] md:gap-4">
                <time
                  datetime={formatDate(post.data.updatedDate ?? post.data.pubDate, 'iso')}
                  class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-white/48 md:-ml-16 md:pt-5"
                >
                  {formatDate(post.data.updatedDate ?? post.data.pubDate, 'dot')}
                </time>

                <a
                  href={`/posts/${post.id}`}
                  class:list={[
                    'verge-card-link grid overflow-hidden p-0',
                    post.data.cover ? 'md:grid-cols-[18rem_minmax(0,1fr)]' : tileAccents[index % tileAccents.length],
                  ]}
                >
                  {post.data.cover && (
                    <figure class="h-56 border-b border-white/28 bg-[var(--theme-surface-soft)] md:h-full md:min-h-56 md:border-b-0 md:border-r">
                      <LqipImage
                        src={post.data.cover}
                        alt={post.data.title}
                        width={520}
                        height={390}
                        loading="lazy"
                        decoding="async"
                        format="webp"
                        class="h-full w-full object-cover"
                      />
                    </figure>
                  )}

                  <div class="flex min-h-56 flex-col justify-between gap-6 p-5">
                    <div>
                      <p class="verge-kicker opacity-65">#{tag}</p>
                      <h3 class="verge-heading mt-3 text-[clamp(1.65rem,3vw,2.8rem)]">{post.data.title}</h3>
                      {post.data.description && <p class="mt-3 line-clamp-2 text-sm leading-6 opacity-72">{post.data.description}</p>}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <p class="py-10 text-center text-white/58">这个标签下暂无文章。</p>
        )}
      </section>

      <Pagination {page} baseUrl={`/tags/${encodedTag}`} class="mx-auto mt-8 max-w-4xl" />
    </section>
  </div>
</Layout>
