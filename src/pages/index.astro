---
import { SITE, SOCIAL_LINKS } from '~/config.ts'
import { getAllNotes, getAllPosts, getAllProjects } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'
import TextType from '~/components/reactbits/TextType'
import SiteBackground from '~/components/base/SiteBackground.astro'

const cleanDescription = SITE.description.replace(/^👋\s*/, '')
const [posts, notes, projects] = await Promise.all([getAllPosts(), getAllNotes(), getAllProjects()])
const latestPosts = posts.slice(0, 5)
const latestNotes = notes.slice(0, 3)
const latestProjects = projects.slice(0, 3)
const githubLink = SOCIAL_LINKS.find((item) => item.name === 'github')
const introPhrases = [
  '前端开发与设计实践',
  '工程效率与工具链',
  '开源贡献与产品构建',
]
---

<Layout title="首页" description={SITE.description}>
  <SiteBackground />
  <div class="antfu-page antfu-home">
    <section class="antfu-hero" aria-labelledby="home-title">
      <h1 id="home-title" class="antfu-title">
        {SITE.author}
      </h1>

      <p class="antfu-greeting">
        Hey! I'm Ethan, a frontend developer.
      </p>

      <p>{cleanDescription}</p>

      <p>
        我主要记录 <a href="/posts">前端开发</a>、工程实践、工具配置和产品构建中的经验。
        更短的排查过程、片段和临时想法会放在 <a href="/notes">笔记</a> 里；
        一些长期维护的小工具和站点实验整理在 <a href="/projects">项目</a> 页面。
      </p>

      <p>
        写代码之外，我也会拍一些 <a href="/photos">照片</a>，记录城市、旅行和生活里的细节。
        这个站点就是这些内容的归档：慢慢写，慢慢整理，也慢慢迭代。
      </p>

      <p class="antfu-typewriter">
        <TextType
          client:visible
          as="span"
          text={introPhrases}
          typingSpeed={80}
          deletingSpeed={40}
          pauseDuration={2500}
          loop={true}
          showCursor={true}
          cursorCharacter="_"
        />
      </p>
    </section>

    {latestPosts.length > 0 && (
      <section class="antfu-section">
        <h2 class="antfu-section-title">Recent Posts</h2>
        <ul class="antfu-list">
          {latestPosts.map((post) => (
            <li class="antfu-list-item">
              <a href={`/posts/${post.id}`} class="antfu-list-link">
                <span class="antfu-list-title">{post.data.title}</span>
                <time class="antfu-list-date">{formatDate(post.data.updatedDate ?? post.data.pubDate, 'short')}</time>
              </a>
            </li>
          ))}
        </ul>
        <p class="antfu-more"><a href="/posts">View all posts →</a></p>
      </section>
    )}

    {latestNotes.length > 0 && (
      <section class="antfu-section">
        <h2 class="antfu-section-title">Recent Notes</h2>
        <ul class="antfu-list">
          {latestNotes.map((note) => (
            <li class="antfu-list-item">
              <a href={`/notes/${note.id}`} class="antfu-list-link">
                <span class="antfu-list-title">{note.data.title}</span>
                <time class="antfu-list-date">{formatDate(note.data.updatedDate ?? note.data.pubDate, 'short')}</time>
              </a>
            </li>
          ))}
        </ul>
        <p class="antfu-more"><a href="/notes">View all notes →</a></p>
      </section>
    )}

    {latestProjects.length > 0 && (
      <section class="antfu-section">
        <h2 class="antfu-section-title">Projects</h2>
        <ul class="antfu-list">
          {latestProjects.map((project) => (
            <li class="antfu-list-item">
              <a
                href={project.data.website || project.data.githubUrl || '/projects'}
                class="antfu-list-link"
                target={project.data.website ? '_blank' : undefined}
                rel={project.data.website ? 'noreferrer' : undefined}
              >
                <span class="antfu-list-title">{project.data.name}</span>
                {project.data.website && <span class="antfu-list-date">↗</span>}
              </a>
            </li>
          ))}
        </ul>
        <p class="antfu-more"><a href="/projects">View all projects →</a></p>
      </section>
    )}

    <hr class="antfu-divider" />

    <section class="antfu-section antfu-find">
      <h2 class="antfu-section-title">Find me on</h2>
      <p class="antfu-social">
        {githubLink && <a href={githubLink.url} target="_blank" rel="noreferrer">GitHub</a>}
        <a href="/atom.xml">RSS</a>
        <a href="/friends">Friends</a>
      </p>
    </section>
  </div>
</Layout>

<style>
  .antfu-home {
    position: relative;
    z-index: 1;
    padding-block: clamp(3.5rem, 9vw, 5.5rem) 2rem;
    color: var(--theme-text);
  }

  .antfu-hero {
    margin-bottom: 3.25rem;
  }

  .antfu-title {
    margin: 0 0 1.35rem;
    color: var(--theme-text);
    font-family: var(--font-geist-mono);
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .antfu-hero p {
    margin: 1.15em 0;
  }

  .antfu-greeting {
    margin-top: 0;
    font-size: 1rem;
  }

  .antfu-typewriter {
    margin-top: 1.5rem;
    opacity: var(--opacity-muted);
    font-size: 0.875rem;
    min-height: 1.5em;
  }
  .antfu-typewriter :global(.text-type) {
    font-family: var(--font-geist-mono);
  }
  .antfu-typewriter :global(.text-type span) {
    color: var(--theme-text);
    opacity: 0.8;
  }
  .antfu-section { margin-bottom: 2.5rem; }
  .antfu-section-title {
    font-size: 0.875rem;
    font-weight: 600;
    opacity: var(--opacity-muted);
    margin: 0 0 0.75rem;
  }

  .antfu-list { list-style: none; padding: 0; margin: 0; }
  .antfu-list-item { margin: 0; }
  .antfu-list-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.38em 0;
    text-decoration: none;
    color: var(--theme-text);
    transition: opacity 200ms ease;
  }
  .antfu-list-link:hover { opacity: var(--opacity-secondary); }
  .antfu-list-title {
    min-width: 0;
  }
  .antfu-list-date {
    flex-shrink: 0;
    font-size: 0.8125rem;
    opacity: var(--opacity-muted);
    text-decoration: none;
  }

  .antfu-more {
    margin: 0.85rem 0 0;
    font-size: 0.875rem;
  }

  .antfu-divider {
    border: 0;
    border-top: 1px solid hsl(var(--border));
    margin: 3rem 0 2.25rem;
    opacity: var(--opacity-faint);
  }

  .antfu-find {
    margin-bottom: 0;
  }

  .antfu-social { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 0; }
  .antfu-social a { text-decoration: none; }
  .antfu-social a:hover { opacity: var(--opacity-secondary); }

  @media (max-width: 520px) {
    .antfu-home {
      padding-top: 2.75rem;
    }

    .antfu-list-link {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.15rem;
      padding-block: 0.5em;
    }
  }
</style>
