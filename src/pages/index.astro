---
import { SITE, SOCIAL_LINKS } from '~/config.ts'
import Layout from '~/layouts/Layout.astro'
import TextType from '~/components/reactbits/TextType'
import SiteBackground from '~/components/base/SiteBackground.astro'
import Threads from '~/components/reactbits/Threads'

const githubLink = SOCIAL_LINKS.find((item) => item.name === 'github')
const introPhrases = [
  '前端开发与设计实践',
  '工程效率与工具链',
  '开源贡献与产品构建',
]
---

<Layout title="首页" description={SITE.description}>
  <SiteBackground hideSilk />
  <div class="threads-bg" aria-hidden="true">
    <Threads client:visible color={[0.9, 0.9, 0.9]} amplitude={0.6} />
  </div>
  <div class="magi-page magi-home">
    <section class="magi-hero" aria-labelledby="home-title">
      <h1 id="home-title" class="magi-title">
        {SITE.author}
      </h1>

      <p class="magi-greeting">
        我是 Ethan Young，坐标南京。
      </p>

      <p>程序员、家人、朋友——以及对生活保持好奇的普通人。做了十年前端，一直想认真写点什么，总被日常琐事搁置。</p>

      <p>
        趁这次重建博客，正式开写。<a href="/posts">文章</a>记技术思考和生活感悟，<a href="/notes">笔记</a>收日常碎片，<a href="/projects">项目</a>存实验成果，<a href="/photos">照片</a>留身边细节。
      </p>

      <p>
        站点用 Astro 搭建，部署在 Vercel——像写代码一样，追求简洁和效率。不求更新频率，只求每篇都值得留下。生活如同 git，每一次 commit 都是在往自己的人生推进一步。
      </p>

      <p class="magi-typewriter">
        <TextType
          client:visible
          as="span"
          text={introPhrases}
          typingSpeed={80}
          deletingSpeed={40}
          pauseDuration={2500}
          loop={true}
          showCursor={true}
          cursorCharacter="_"
        />
      </p>
    </section>

    <hr class="magi-divider" />

    <section class="magi-section magi-find">
      <h2 class="magi-section-title">Find me on</h2>
      <p class="magi-social">
        {githubLink && <a href={githubLink.url} target="_blank" rel="noreferrer">GitHub</a>}
        <a href="/atom.xml">RSS</a>
        <a href="/friends">Friends</a>
      </p>
    </section>
  </div>
</Layout>

<style>
  .threads-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.55;
  }

  .magi-home {
    position: relative;
    z-index: 1;
    padding-block: clamp(3.5rem, 9vw, 5.5rem) 2rem;
    padding-inline: calc(1.25rem + env(safe-area-inset-left)) calc(1.25rem + env(safe-area-inset-right));
    color: var(--theme-text);
    font-family: var(--article-body);
  }

  .magi-hero {
    margin-bottom: 3.25rem;
  }

  .magi-title {
    margin: 0 0 1.35rem;
    color: var(--theme-text);
    font-family: var(--article-display);
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .magi-hero p {
    margin: 1.15em 0;
  }

  .magi-greeting {
    margin-top: 0;
    font-size: 1rem;
  }

  .magi-typewriter {
    margin-top: 1.5rem;
    opacity: var(--opacity-muted);
    font-family: var(--font-geist-mono);
    font-size: 0.875rem;
    min-height: 1.5em;
  }
  .magi-typewriter :global(.text-type) {
    font-family: var(--font-geist-mono);
  }
  .magi-typewriter :global(.text-type span) {
    color: var(--brand);
    opacity: 0.85;
  }
  .magi-section { margin-bottom: 2.5rem; }
  .magi-section-title {
    font-family: var(--font-geist-mono);
    font-size: 0.875rem;
    font-weight: 600;
    opacity: var(--opacity-muted);
    margin: 0 0 0.75rem;
  }

  .magi-divider {
    border: 0;
    border-top: 1px solid hsl(var(--border));
    margin: 3rem 0 2.25rem;
    opacity: var(--opacity-faint);
  }

  .magi-find {
    margin-bottom: 0;
  }

  .magi-social { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 0; }
  .magi-social a { text-decoration: none; }
  .magi-social a:hover { opacity: 1; color: var(--brand); }

  @media (max-width: 520px) {
    .magi-home {
      padding-top: 2.75rem;
    }
  }
</style>
