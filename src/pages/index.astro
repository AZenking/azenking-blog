---
import { SITE } from '~/config.ts'
import Layout from '~/layouts/Layout.astro'

const cleanDescription = SITE.description.replace(/^👋\s*/, '')
---

<Layout title="Home" description={SITE.description}>
  <div class="apple-ui relative isolate overflow-hidden px-6 sm:px-8">
    <div class="pointer-events-none absolute inset-x-0 top-[-14rem] -z-10 h-[30rem] bg-[radial-gradient(65%_60%_at_50%_60%,rgba(183,190,200,0.34),rgba(255,255,255,0))] dark:bg-[radial-gradient(65%_60%_at_50%_60%,rgba(90,101,116,0.28),rgba(0,0,0,0))]">
    </div>

    <section id="about" class="mx-auto flex min-h-[calc(100svh-11rem)] w-full max-w-4xl items-center py-20 sm:py-28">
      <div class="w-full">
        <p class="text-[0.68rem] font-medium uppercase tracking-[0.16em] text-muted-foreground/85">Personal Blog</p>
        <h1 class="mt-4 text-balance text-[clamp(2.4rem,7vw,5rem)] font-semibold leading-[1.03] tracking-[-0.045em] text-foreground">
          {SITE.title}
        </h1>
        <p class="mt-8 max-w-[34ch] text-pretty text-[clamp(1.05rem,2.2vw,1.4rem)] font-normal leading-[1.75] tracking-[-0.01em] text-foreground/70 dark:text-foreground/72">
          {cleanDescription}
        </p>
      </div>
    </section>
  </div>
</Layout>
