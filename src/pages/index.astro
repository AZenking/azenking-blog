---
import { SITE } from '~/config.ts'
import { getAllNotes, getAllPosts, getAllProjects } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'

import Peep1 from '~/assets/bust/peep-1.svg?url'
import Peep2 from '~/assets/bust/peep-2.svg?url'
import Peep8 from '~/assets/bust/peep-8.svg?url'
import Peep10 from '~/assets/bust/peep-10.svg?url'
import Peep15 from '~/assets/bust/peep-15.svg?url'
import Peep17 from '~/assets/bust/peep-17.svg?url'
import Peep22 from '~/assets/bust/peep-22.svg?url'
import Peep24 from '~/assets/bust/peep-24.svg?url'
import Peep29 from '~/assets/bust/peep-29.svg?url'
import Peep31 from '~/assets/bust/peep-31.svg?url'
import Peep36 from '~/assets/bust/peep-36.svg?url'
import Peep38 from '~/assets/bust/peep-38.svg?url'
import Peep43 from '~/assets/bust/peep-43.svg?url'
import Peep50 from '~/assets/bust/peep-50.svg?url'
import Peep57 from '~/assets/bust/peep-57.svg?url'
import Peep64 from '~/assets/bust/peep-64.svg?url'
import Peep71 from '~/assets/bust/peep-71.svg?url'
import Peep78 from '~/assets/bust/peep-78.svg?url'
import Peep85 from '~/assets/bust/peep-85.svg?url'
import Peep92 from '~/assets/bust/peep-92.svg?url'

const cleanDescription = SITE.description.replace(/^👋\s*/, '')
const [posts, notes, projects] = await Promise.all([getAllPosts(), getAllNotes(), getAllProjects()])

const busts = [
  { src: Peep2, alt: 'Bust portrait 0', height: 'h-[7.5rem] sm:h-[8.5rem] lg:h-[9.5rem]' },
  { src: Peep1, alt: 'Bust portrait 1', height: 'h-28 sm:h-32 lg:h-36' },
  { src: Peep8, alt: 'Bust portrait 2', height: 'h-36 sm:h-40 lg:h-44' },
  { src: Peep10, alt: 'Bust portrait 2b', height: 'h-[8rem] sm:h-[9rem] lg:h-[10rem]' },
  { src: Peep15, alt: 'Bust portrait 3', height: 'h-[8rem] sm:h-[9rem] lg:h-[10rem]' },
  { src: Peep17, alt: 'Bust portrait 3b', height: 'h-32 sm:h-36 lg:h-40' },
  { src: Peep22, alt: 'Bust portrait 4', height: 'h-[7rem] sm:h-[8rem] lg:h-[9rem]' },
  { src: Peep24, alt: 'Bust portrait 4b', height: 'h-[8.25rem] sm:h-[9.25rem] lg:h-[10.25rem]' },
  { src: Peep29, alt: 'Bust portrait 5', height: 'h-40 sm:h-44 lg:h-48' },
  { src: Peep31, alt: 'Bust portrait 5b', height: 'h-[7.75rem] sm:h-[8.75rem] lg:h-[9.75rem]' },
  { src: Peep36, alt: 'Bust portrait 6', height: 'h-32 sm:h-36 lg:h-40' },
  { src: Peep38, alt: 'Bust portrait 6b', height: 'h-36 sm:h-40 lg:h-44' },
  { src: Peep43, alt: 'Bust portrait 7', height: 'h-[8rem] sm:h-[9rem] lg:h-[10rem]' },
  { src: Peep50, alt: 'Bust portrait 8', height: 'h-36 sm:h-40 lg:h-44' },
  { src: Peep57, alt: 'Bust portrait 9', height: 'h-28 sm:h-32 lg:h-36' },
  { src: Peep64, alt: 'Bust portrait 10', height: 'h-32 sm:h-36 lg:h-40' },
  { src: Peep71, alt: 'Bust portrait 11', height: 'h-[7.75rem] sm:h-[8.75rem] lg:h-[9.75rem]' },
  { src: Peep78, alt: 'Bust portrait 12', height: 'h-40 sm:h-44 lg:h-48' },
  { src: Peep85, alt: 'Bust portrait 13', height: 'h-[8rem] sm:h-[9rem] lg:h-[10rem]' },
  { src: Peep92, alt: 'Bust portrait 14', height: 'h-[8.5rem] sm:h-[9.5rem] lg:h-[10.5rem]' },
]
---

<Layout title="首页" description={SITE.description} fullWidth hideFooter>
  <section class="relative min-h-[calc(100svh-5rem)] overflow-hidden bg-[#131313] text-white">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-white/35"></div>
    <div class="pointer-events-none absolute left-0 top-0 h-28 w-28 bg-[#3cffd0] sm:h-36 sm:w-36"></div>
    <div class="pointer-events-none absolute right-0 top-0 h-20 w-32 bg-[#5200ff] sm:h-28 sm:w-44"></div>
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 border-t border-white/35 bg-[#1b1b1b]"></div>

    <div class="relative mx-auto flex min-h-[calc(100svh-5rem)] w-full max-w-[82rem] flex-col items-center justify-center px-4 pb-60 pt-16 text-center sm:px-6 sm:pb-[17rem] lg:px-8 lg:pb-80">
      <p class="verge-kicker text-white/58">个人归档 / 技术笔记 / 产品实践</p>

      <h1 class="verge-display mt-6 max-w-[8ch] text-balance text-[clamp(5rem,18vw,13.5rem)] leading-[0.76] tracking-normal">
        {'<EY />'}
      </h1>

      <p class="verge-copy mt-5 max-w-[40rem] text-pretty text-base sm:text-lg">
        {cleanDescription}
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/posts" class="verge-button-primary min-w-44">
          阅读文章
        </a>
        <a href="/projects" class="verge-button-secondary min-w-44">
          查看项目
        </a>
      </div>

      <div class="mt-7 grid w-full max-w-[22rem] grid-cols-2 gap-2 text-sm leading-7 text-white/62 sm:flex sm:max-w-none sm:flex-wrap sm:items-center sm:justify-center">
        <a href="/posts" class="verge-pill justify-center">文章 {posts.length}</a>
        <a href="/notes" class="verge-pill justify-center">笔记 {notes.length}</a>
        <a href="/projects" class="verge-pill justify-center">项目 {projects.length}</a>
        <a href="/photos" class="verge-pill justify-center">照片</a>
      </div>
    </div>

    <div class="pointer-events-none absolute inset-x-0 bottom-0 overflow-hidden">
      <div class="relative left-1/2 flex w-[112vw] min-w-max -translate-x-1/2 translate-y-3 items-end justify-center -space-x-4 sm:translate-y-4 sm:-space-x-6 lg:translate-y-5 lg:-space-x-8 xl:-space-x-10">
        {busts.map((bust, index) => (
          <div class:list={['shrink-0 overflow-hidden opacity-100', bust.height]}>
            <img
              src={bust.src}
              alt={bust.alt}
              class:list={[
                'themed-svg h-full w-auto -scale-x-100 object-contain object-bottom',
                index % 5 === 0 && 'opacity-90',
              ]}
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
