---
import Layout from '~/layouts/Layout.astro'
import SiteBackground from '~/components/base/SiteBackground.astro'
---

<Layout title="404 页面未找到" description="页面未找到">
  <SiteBackground />
  <div class="not-found">
    <p class="line line-title">&gt; 404: 找不到这个路径</p>
    <p class="line line-path">&gt; 路径&nbsp;&nbsp;<code>{Astro.url.pathname}</code></p>
    <p class="line line-hint">这个链接可能已经移动、归档、或还没写完。</p>
    <nav class="links">
      <a href="/">首页</a>
      <a href="/posts">文章</a>
      <a href="/notes">笔记</a>
      <a href="javascript:history.back()">返回上一页</a>
    </nav>
  </div>
</Layout>

<style>
  .not-found {
    position: relative;
    z-index: 1;
    max-width: var(--content-width);
    margin-inline: auto;
    padding: 5rem 1rem 2rem;
  }

  .line {
    margin-block: 0.5em;
    font-family: var(--font-geist-mono);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .line-title {
    color: var(--theme-text);
    opacity: 1;
    font-weight: 600;
  }

  .line-path {
    opacity: var(--opacity-secondary);
  }

  .line-path code {
    font-family: inherit;
    font-size: inherit;
    word-break: break-all;
  }

  .line-hint {
    margin-block: 1rem;
    opacity: var(--opacity-muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-top: 1.5rem;
  }

  .links a {
    font-family: var(--font-geist-mono);
    font-size: 0.875rem;
    color: var(--theme-text);
    text-decoration: none;
    opacity: var(--opacity-muted);
    transition: opacity 200ms ease;
  }

  .links a:hover {
    opacity: 1;
  }
</style>
