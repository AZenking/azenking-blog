---
import Layout from '~/layouts/Layout.astro'
---

<Layout title="页面未找到" description="页面未找到，可能已移动、取消发布或从 Ethan Young 的博客归档中移除。你可以返回首页、文章归档或标签索引继续浏览。" fullWidth>
  <div class="fly-shell flex min-h-[calc(100svh-10rem)] items-center px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <section class="fly-card mx-auto w-full max-w-4xl p-8 text-center sm:p-12">
      <p class="fly-kicker">404</p>
      <h1 class="fly-display mt-5 text-[clamp(3rem,9vw,7rem)]">页面未找到</h1>
      <p class="fly-copy mx-auto mt-6 max-w-[36rem] text-base sm:text-lg">
        你访问的页面可能已经移动、取消发布，或从博客归档中移除。
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="fly-button-primary"
        >
          返回首页
        </a>
        <button
          type="button"
          onclick="history.back()"
          class="fly-button-secondary cursor-pointer"
        >
          返回上一页
        </button>
      </div>
    </section>
  </div>
</Layout>
