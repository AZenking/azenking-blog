---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import Comment from '~/components/posts/base/Comment.astro'
import Prose from '~/components/posts/base/Prose.astro'
import { SITE } from '~/config'
import { getAllNotes } from '~/lib/data'
import { getSeoDescription } from '~/lib/seo'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

export async function getStaticPaths() {
  const sortedNotes = await getAllNotes()
  return sortedNotes.map((note, index) => ({
    params: { id: note.id },
    props: {
      note,
      prev: index + 1 < sortedNotes.length ? sortedNotes[index + 1] : null,
      next: index > 0 ? sortedNotes[index - 1] : null,
    },
  }))
}

interface Props {
  note: CollectionEntry<'notes'>
  prev: CollectionEntry<'notes'> | null
  next: CollectionEntry<'notes'> | null
}

const { note, prev, next }: Props = Astro.props
const { data: frontmatter } = note
const { Content } = await render(note)

const tags = frontmatter.tags ?? []
const publishedDate = formatDate(frontmatter.pubDate)
const updatedDate = frontmatter.updatedDate ? formatDate(frontmatter.updatedDate) : null
const canonicalUrl = new URL(`/notes/${note.id}`, SITE.website).toString()
const displayAuthor = frontmatter.author || SITE.author
const noteImage = new URL(frontmatter.ogImage?.src ?? frontmatter.cover?.src ?? SITE.ogImage, SITE.website).toString()
const noteDescription = getSeoDescription({
  title: frontmatter.title,
  description: frontmatter.description,
  tags,
  contentType: '笔记',
})
---

<Layout
  title={frontmatter.title}
  description={noteDescription}
  image={noteImage}
  ogType="article"
  publishedTime={frontmatter.pubDate.toISOString()}
  modifiedTime={(frontmatter.updatedDate ?? frontmatter.pubDate).toISOString()}
  author={displayAuthor}
  tags={tags}
  fullWidth
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    "headline": frontmatter.title,
    "description": noteDescription,
    "datePublished": frontmatter.pubDate.toISOString(),
    "dateModified": (frontmatter.updatedDate ?? frontmatter.pubDate).toISOString(),
    "author": { "@type": "Person", "name": displayAuthor },
    "publisher": { "@type": "Person", "name": SITE.author },
    "image": noteImage,
    "inLanguage": SITE.lang,
    "keywords": tags.join(', '),
    "url": canonicalUrl,
  })} />

  <article class="antfu-article antfu-article-notes">
    <a href="/notes" class="antfu-back">Notes / Archive</a>

    <header class="antfu-article-header">
      <h1 class="antfu-article-title">{frontmatter.title}</h1>
      {frontmatter.description && (
        <p class="antfu-article-desc">{frontmatter.description}</p>
      )}
      <div class="antfu-article-meta">
        <span>By {displayAuthor}</span>
        <span>·</span>
        <time datetime={frontmatter.pubDate.toISOString()}>{publishedDate}</time>
        {updatedDate && <><span>·</span><span>Updated {updatedDate}</span></>}
      </div>
      {tags.length > 0 && (
        <div class="antfu-article-tags">
          {tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="antfu-article-tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    <Prose class="antfu-article-body">
      <Content />
    </Prose>

    {(prev || next) && (
      <nav class="antfu-adjacent">
        {next ? (
          <a href={`/notes/${next.id}`} class="antfu-adjacent-link">
            <span class="antfu-adjacent-label">← 上一篇笔记</span>
            <span class="antfu-adjacent-title">{next.data.title}</span>
          </a>
        ) : <span></span>}
        {prev ? (
          <a href={`/notes/${prev.id}`} class="antfu-adjacent-link antfu-adjacent-right">
            <span class="antfu-adjacent-label">下一篇笔记 →</span>
            <span class="antfu-adjacent-title">{prev.data.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}

    {frontmatter.comment !== false && (
      <section class="antfu-comments">
        <Comment id={note.id} title={frontmatter.title} />
      </section>
    )}
  </article>

  <script>
    document.querySelectorAll('[data-copy-link]').forEach((button) => {
      button.addEventListener('click', async () => {
        const url = button.getAttribute('data-copy-link')
        if (!url) return
        try {
          await navigator.clipboard.writeText(url)
          button.setAttribute('aria-label', '链接已复制')
        } catch {
          window.location.href = url
        }
      })
    })
  </script>
</Layout>

<style>
  /* Notes 详情页复用 .antfu-article 的容器样式（统一在 markdown.css 的
     "Editorial article container" 段落，由 /posts/[id] 和 /notes/[id] 共享）。
     此处只补充 notes 特有的克制差异：标题不那么巨大、左对齐、不强制居中 meta。 */

  .antfu-article-notes {
    padding: clamp(3rem, 6vw, 5rem) 1.25rem 3rem;
  }

  .antfu-article-notes .antfu-back {
    margin-bottom: clamp(2rem, 4vw, 2.75rem);
  }

  .antfu-article-notes .antfu-article-header {
    width: min(100%, 48rem);
    margin-inline: auto;
    margin-bottom: clamp(2.25rem, 4vw, 3rem);
    text-align: left;
  }

  .antfu-article-notes .antfu-article-title {
    color: var(--article-ink);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .antfu-article-notes .antfu-article-desc {
    margin: clamp(0.85rem, 1.8vw, 1.25rem) 0 0;
    max-width: none;
    color: var(--article-soft);
    font-weight: 400;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.5;
  }

  .antfu-article-notes .antfu-article-meta {
    justify-content: flex-start;
    margin-top: clamp(1.25rem, 2.5vw, 1.75rem);
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  .antfu-article-notes .antfu-article-tags {
    justify-content: flex-start;
    margin-top: 0.75rem;
  }

  .antfu-article-notes .antfu-adjacent {
    width: min(100%, 42rem);
    margin: 2.5rem auto 0;
  }

  @media (max-width: 720px) {
    .antfu-article-notes {
      padding-inline: 1rem;
      padding-top: 2.5rem;
    }

    .antfu-article-notes .antfu-article-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    .antfu-article-notes .antfu-adjacent {
      grid-template-columns: 1fr;
    }
  }
</style>
