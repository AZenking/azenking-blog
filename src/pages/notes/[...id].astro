---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import LqipImage from '~/components/base/LqipImage.astro'
import Prose from '~/components/posts/base/Prose.astro'
import PostKindTabs from '~/components/posts/base/PostKindTabs.astro'
import { SITE } from '~/config'
import { getAllNotes } from '~/lib/data'
import { getSeoDescription } from '~/lib/seo'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

export async function getStaticPaths() {
  const sortedNotes = await getAllNotes()
  return sortedNotes.map((note, index) => ({
    params: { id: note.id },
    props: {
      note,
      notes: sortedNotes,
      prev: index + 1 < sortedNotes.length ? sortedNotes[index + 1] : null,
      next: index > 0 ? sortedNotes[index - 1] : null,
    },
  }))
}

interface Props {
  note: CollectionEntry<'notes'>
  notes: CollectionEntry<'notes'>[]
  prev: CollectionEntry<'notes'> | null
  next: CollectionEntry<'notes'> | null
}

const { note, notes, prev, next }: Props = Astro.props
const { data: frontmatter } = note
const { Content } = await render(note)

const tags = frontmatter.tags ?? []
const publishedDate = formatDate(frontmatter.pubDate)
const updatedDate = frontmatter.updatedDate ? formatDate(frontmatter.updatedDate) : null
const canonicalUrl = new URL(`/notes/${note.id}`, SITE.website).toString()
const displayAuthor = frontmatter.author || SITE.author
const noteImage = new URL(frontmatter.ogImage?.src ?? frontmatter.cover?.src ?? SITE.ogImage, SITE.website).toString()
const noteDescription = getSeoDescription({
  title: frontmatter.title,
  description: frontmatter.description,
  tags,
  contentType: '笔记',
})

const currentTags = new Set(tags)
const relatedNotes = notes
  .filter((candidate) => candidate.id !== note.id)
  .map((candidate) => {
    const candidateTags = candidate.data.tags ?? []
    const overlap = candidateTags.filter((tag) => currentTags.has(tag)).length
    const referenceDate = candidate.data.updatedDate ?? candidate.data.pubDate
    return {
      candidate,
      overlap,
      timestamp: referenceDate.getTime(),
    }
  })
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap
    return b.timestamp - a.timestamp
  })
  .slice(0, 3)
  .map((item) => item.candidate)
---

<Layout
  title={frontmatter.title}
  description={noteDescription}
  image={noteImage}
  ogType="article"
  publishedTime={frontmatter.pubDate.toISOString()}
  modifiedTime={(frontmatter.updatedDate ?? frontmatter.pubDate).toISOString()}
  author={displayAuthor}
  tags={tags}
  fullWidth
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl,
    },
    "headline": frontmatter.title,
    "description": noteDescription,
    "datePublished": frontmatter.pubDate.toISOString(),
    "dateModified": (frontmatter.updatedDate ?? frontmatter.pubDate).toISOString(),
    "author": { "@type": "Person", "name": displayAuthor },
    "publisher": {
      "@type": "Person",
      "name": SITE.author,
    },
    "image": noteImage,
    "inLanguage": SITE.lang,
    "keywords": tags.join(', '),
    "url": canonicalUrl,
  })} />
  <div class="verge-article-shell">
    <section class="verge-article-container">
      <a
        href="/notes"
        class="verge-article-back verge-focus"
      >
        <span class="icon-[ph--arrow-left] size-5"></span>
        <span>返回笔记</span>
      </a>

      <div class="mt-6">
        <PostKindTabs active="notes" />
      </div>

      <header class="verge-article-header">
        <div>
          <div class="flex flex-wrap gap-2">
            {tags.slice(0, 4).map((tag) => (
              <a
                href={`/tags/${encodeURIComponent(tag)}`}
                class="verge-pill verge-focus"
              >
                {tag}
              </a>
            ))}
          </div>

          <h1 class="verge-article-title mt-6">{frontmatter.title}</h1>

          {frontmatter.description && (
            <p class="verge-article-deck mt-6">{frontmatter.description}</p>
          )}
        </div>

        <aside class="grid gap-5">
          <div class="verge-article-meta">
            <time datetime={frontmatter.pubDate.toISOString()}>{publishedDate}</time>
            {updatedDate && <p>更新 {updatedDate}</p>}
            {frontmatter.author && <p>{frontmatter.author}</p>}
          </div>

          <div class="verge-article-actions">
            <a class="verge-article-action verge-focus" href={canonicalUrl}>
              <span class="icon-[ph--link] size-4"></span>
              <span>链接</span>
            </a>
            <button class="verge-article-action verge-focus cursor-pointer" type="button" data-copy-link={canonicalUrl}>
              <span class="icon-[ph--share-network] size-4"></span>
              <span>分享</span>
            </button>
          </div>
        </aside>
      </header>

      {frontmatter.cover && (
        <figure class="verge-article-hero">
          <div class="aspect-[1200/630]">
            <LqipImage
              src={frontmatter.cover}
              alt={frontmatter.title}
              width={1200}
              height={630}
              loading="eager"
              decoding="async"
              format="webp"
              class="h-full w-full object-cover"
            />
          </div>
        </figure>
      )}

      <div class="verge-article-body-grid">
        <aside class="verge-article-rail" aria-label="笔记详情">
          <p>{tags[0] ?? 'Note'}</p>
          <p>{publishedDate}</p>
          {updatedDate && <p>已更新</p>}
        </aside>

        <main>
          <Prose class="verge-article-body">
            <Content />
          </Prose>
        </main>
      </div>

      {(prev || next) && (
        <nav class="border-t border-white/35 py-10" aria-label="笔记导航">
          <div class="grid gap-4 sm:grid-cols-2">
            {next ? (
              <a
                href={`/notes/${next.id}`}
                class="verge-card-link px-5 py-4"
              >
                <p class="text-[0.72rem] uppercase tracking-[0.1em] text-white/52">上一篇笔记</p>
                <p class="mt-2 text-base leading-7">{next.data.title}</p>
              </a>
            ) : (
              <div></div>
            )}

            {prev ? (
              <a
                href={`/notes/${prev.id}`}
                class="verge-card-link px-5 py-4 sm:text-right"
              >
                <p class="text-[0.72rem] uppercase tracking-[0.1em] text-white/52">下一篇笔记</p>
                <p class="mt-2 text-base leading-7">{prev.data.title}</p>
              </a>
            ) : (
              <div></div>
            )}
          </div>
        </nav>
      )}

      {relatedNotes.length > 0 && (
        <section class="border-t border-white/35 py-10">
          <h2 class="text-[0.78rem] uppercase tracking-[0.14em] text-white/45">相关笔记</h2>
          <div class="mt-5 space-y-4">
            {relatedNotes.map((related) => {
              const relatedDate = related.data.updatedDate ?? related.data.pubDate
              return (
                <a
                  href={`/notes/${related.id}`}
                  class="verge-card-link block px-5 py-4"
                >
                  <p class="text-[0.75rem] opacity-60">{formatDate(relatedDate)}</p>
                  <h3 class="mt-1.5 text-xl leading-tight tracking-[-0.03em]">{related.data.title}</h3>
                  {related.data.description && (
                    <p class="mt-2 line-clamp-2 text-sm leading-7 text-white/64">{related.data.description}</p>
                  )}
                </a>
              )
            })}
          </div>
        </section>
      )}
    </section>
  </div>

  <script>
    document.querySelectorAll('[data-copy-link]').forEach((button) => {
      button.addEventListener('click', async () => {
        const url = button.getAttribute('data-copy-link')
        if (!url) return
        try {
          await navigator.clipboard.writeText(url)
          button.setAttribute('aria-label', '链接已复制')
        } catch {
          window.location.href = url
        }
      })
    })
  </script>
</Layout>
