---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import Comment from '~/components/posts/base/Comment.astro'
import Prose from '~/components/posts/base/Prose.astro'
import { POSTS_CONFIG, SITE } from '~/config'
import { getAllPosts } from '~/lib/data'
import { getSeoDescription } from '~/lib/seo'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

const LICENSE_LINKS: Record<string, string> = {
  'CC-BY-4.0': 'https://creativecommons.org/licenses/by/4.0/',
  'CC-BY-SA-4.0': 'https://creativecommons.org/licenses/by-sa/4.0/',
  'CC-BY-NC-4.0': 'https://creativecommons.org/licenses/by-nc/4.0/',
  'CC-BY-NC-SA-4.0': 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
  'CC-BY-ND-4.0': 'https://creativecommons.org/licenses/by-nd/4.0/',
  'CC-BY-NC-ND-4.0': 'https://creativecommons.org/licenses/by-nc-nd/4.0/',
  'MIT': 'https://opensource.org/licenses/MIT',
  'Apache-2.0': 'https://www.apache.org/licenses/LICENSE-2.0',
  'GPL-3.0': 'https://www.gnu.org/licenses/gpl-3.0.html',
}

export async function getStaticPaths() {
  const sortedPosts = await getAllPosts()
  return sortedPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prev: index + 1 < sortedPosts.length ? sortedPosts[index + 1] : null,
      next: index > 0 ? sortedPosts[index - 1] : null,
    },
  }))
}

interface Props {
  post: CollectionEntry<'posts'>
  prev: CollectionEntry<'posts'> | null
  next: CollectionEntry<'posts'> | null
}

const { post, prev, next }: Props = Astro.props
const { data: frontmatter } = post
const { Content, remarkPluginFrontmatter } = await render(post)

const tags = frontmatter.tags ?? []
const displayAuthor = frontmatter.author || SITE.author
const minutesRead = remarkPluginFrontmatter?.minutesRead
const publishedDate = formatDate(frontmatter.pubDate)
const updatedDate = frontmatter.updatedDate ? formatDate(frontmatter.updatedDate) : null
const canonicalUrl = new URL(`/posts/${post.id}`, SITE.website).toString()
const licenseLink = frontmatter.license ? LICENSE_LINKS[frontmatter.license] : undefined
const coverImage = frontmatter.cover
const articleImage = new URL(frontmatter.ogImage?.src ?? frontmatter.cover?.src ?? SITE.ogImage, SITE.website).toString()
const articleDescription = getSeoDescription({
  title: frontmatter.title,
  description: frontmatter.description,
  tags,
  contentType: '文章',
})
---

<Layout
  title={frontmatter.title}
  description={articleDescription}
  image={articleImage}
  ogType="article"
  publishedTime={frontmatter.pubDate.toISOString()}
  modifiedTime={(frontmatter.updatedDate ?? frontmatter.pubDate).toISOString()}
  author={displayAuthor}
  tags={tags}
  fullWidth
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    "headline": frontmatter.title,
    "description": articleDescription,
    "datePublished": frontmatter.pubDate.toISOString(),
    "dateModified": (frontmatter.updatedDate ?? frontmatter.pubDate).toISOString(),
    "author": { "@type": "Person", "name": displayAuthor },
    "publisher": { "@type": "Person", "name": SITE.author },
    "image": articleImage,
    "inLanguage": SITE.lang,
    "keywords": tags.join(', '),
    "url": canonicalUrl,
  })} />

  <article class="antfu-article">
    <a href="/posts" class="antfu-back">Posts / Archive</a>

    {coverImage && (
      <figure class="antfu-article-cover">
        <img
          src={coverImage.src}
          width={coverImage.width}
          height={coverImage.height}
          alt={frontmatter.title}
          loading="eager"
          decoding="async"
        />
      </figure>
    )}

    <header class="antfu-article-header">
      <h1 class="antfu-article-title">{frontmatter.title}</h1>
      {frontmatter.description && (
        <p class="antfu-article-desc">{frontmatter.description}</p>
      )}
      <div class="antfu-article-meta">
        <span>By {displayAuthor}</span>
        <span>·</span>
        <time datetime={frontmatter.pubDate.toISOString()}>{publishedDate}</time>
        {minutesRead && <><span>·</span><span>{minutesRead} min read</span></>}
        {updatedDate && <><span>·</span><span>Updated {updatedDate}</span></>}
      </div>
      {tags.length > 0 && (
        <div class="antfu-article-tags">
          {tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="antfu-article-tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    <Prose class="antfu-article-body">
      <Content />
    </Prose>

    {frontmatter.license && (
      <section class="antfu-license">
        <p>
          Licensed under{' '}
          {licenseLink ? (
            <a href={licenseLink} target="_blank" rel="noreferrer">{frontmatter.license}</a>
          ) : (
            <span>{frontmatter.license}</span>
          )}
          {' · '}
          <a href={canonicalUrl}>Permalink ↗</a>
        </p>
      </section>
    )}

    {(prev || next) && (
      <nav class="antfu-adjacent">
        {next ? (
          <a href={`/posts/${next.id}`} class="antfu-adjacent-link">
            <span class="antfu-adjacent-label">← {POSTS_CONFIG.prevPostText}</span>
            <span class="antfu-adjacent-title">{next.data.title}</span>
          </a>
        ) : <span></span>}
        {prev ? (
          <a href={`/posts/${prev.id}`} class="antfu-adjacent-link antfu-adjacent-right">
            <span class="antfu-adjacent-label">{POSTS_CONFIG.nextPostText} →</span>
            <span class="antfu-adjacent-title">{prev.data.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}

    {frontmatter.comment !== false && (
      <section class="antfu-comments">
        <Comment id={post.id} title={frontmatter.title} />
      </section>
    )}
  </article>

  <script>
    document.querySelectorAll('[data-copy-link]').forEach((button) => {
      button.addEventListener('click', async () => {
        const url = button.getAttribute('data-copy-link')
        if (!url) return
        try {
          await navigator.clipboard.writeText(url)
          button.setAttribute('aria-label', '链接已复制')
        } catch {
          window.location.href = url
        }
      })
    })
  </script>
</Layout>

<style>
  /* .antfu-article 容器、返回链接、标题、meta、tags、license、adjacent nav 的样式
     全部统一在 markdown.css 的 "Editorial article container" 段落，由 /posts/[id] 和 /notes/[id] 共享。
     此页不再需要额外的 scoped 样式。 */
</style>
