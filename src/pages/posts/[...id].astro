---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import LqipImage from '~/components/base/LqipImage.astro'
import Comment from '~/components/posts/base/Comment.astro'
import Prose from '~/components/posts/base/Prose.astro'
import { POSTS_CONFIG, SITE } from '~/config'
import { getAllPosts } from '~/lib/data'
import { getSeoDescription } from '~/lib/seo'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

const LICENSE_LINKS: Record<string, string> = {
  'CC-BY-4.0': 'https://creativecommons.org/licenses/by/4.0/',
  'CC-BY-SA-4.0': 'https://creativecommons.org/licenses/by-sa/4.0/',
  'CC-BY-NC-4.0': 'https://creativecommons.org/licenses/by-nc/4.0/',
  'CC-BY-NC-SA-4.0': 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
  'CC-BY-ND-4.0': 'https://creativecommons.org/licenses/by-nd/4.0/',
  'CC-BY-NC-ND-4.0': 'https://creativecommons.org/licenses/by-nc-nd/4.0/',
  'MIT': 'https://opensource.org/licenses/MIT',
  'Apache-2.0': 'https://www.apache.org/licenses/LICENSE-2.0',
  'GPL-3.0': 'https://www.gnu.org/licenses/gpl-3.0.html',
}

export async function getStaticPaths() {
  const sortedPosts = await getAllPosts()
  return sortedPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      posts: sortedPosts,
      prev: index + 1 < sortedPosts.length ? sortedPosts[index + 1] : null,
      next: index > 0 ? sortedPosts[index - 1] : null,
    },
  }))
}

interface Props {
  post: CollectionEntry<'posts'>
  posts: CollectionEntry<'posts'>[]
  prev: CollectionEntry<'posts'> | null
  next: CollectionEntry<'posts'> | null
}

const { post, posts, prev, next }: Props = Astro.props
const { data: frontmatter } = post
const { Content, remarkPluginFrontmatter } = await render(post)

const tags = frontmatter.tags ?? []
const displayAuthor = frontmatter.author || SITE.author
const minutesRead = remarkPluginFrontmatter?.minutesRead
const wordCount = remarkPluginFrontmatter?.wordCount
const publishedDate = formatDate(frontmatter.pubDate)
const updatedDate = frontmatter.updatedDate ? formatDate(frontmatter.updatedDate) : null
const canonicalUrl = new URL(`/posts/${post.id}`, SITE.website).toString()
const licenseLink = frontmatter.license ? LICENSE_LINKS[frontmatter.license] : undefined
const articleImage = new URL(frontmatter.ogImage?.src ?? frontmatter.cover?.src ?? SITE.ogImage, SITE.website).toString()
const articleDescription = getSeoDescription({
  title: frontmatter.title,
  description: frontmatter.description,
  tags,
  contentType: '文章',
})

const currentTags = new Set(tags)
const relatedPosts = posts
  .filter((candidate) => candidate.id !== post.id)
  .map((candidate) => {
    const candidateTags = candidate.data.tags ?? []
    const overlap = candidateTags.filter((tag) => currentTags.has(tag)).length
    const referenceDate = candidate.data.updatedDate ?? candidate.data.pubDate
    return {
      candidate,
      overlap,
      timestamp: referenceDate.getTime(),
    }
  })
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap
    return b.timestamp - a.timestamp
  })
  .slice(0, 3)
  .map((item) => item.candidate)
---

<Layout
  title={frontmatter.title}
  description={articleDescription}
  image={articleImage}
  ogType="article"
  publishedTime={frontmatter.pubDate.toISOString()}
  modifiedTime={(frontmatter.updatedDate ?? frontmatter.pubDate).toISOString()}
  author={displayAuthor}
  tags={tags}
  fullWidth
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl,
    },
    "headline": frontmatter.title,
    "description": articleDescription,
    "datePublished": frontmatter.pubDate.toISOString(),
    "dateModified": (frontmatter.updatedDate ?? frontmatter.pubDate).toISOString(),
    "author": { "@type": "Person", "name": displayAuthor },
    "publisher": {
      "@type": "Person",
      "name": SITE.author,
    },
    "image": articleImage,
    "inLanguage": SITE.lang,
    "keywords": tags.join(', '),
    "url": canonicalUrl,
  })} />
  <div class="fly-post-article-shell">
    <section class="fly-post-article-hero">
      <div class="fly-post-container">
        <a href="/posts" class="fly-post-back">
          <span class="icon-[ph--arrow-left] size-5"></span>
          <span>返回文章</span>
        </a>

        <div class="fly-post-article-grid">
          <header class="fly-post-article-header">
            <div class="fly-post-meta-line">
              <span>By {displayAuthor}</span>
              <time datetime={frontmatter.pubDate.toISOString()}>
                {[publishedDate, minutesRead && `${minutesRead} min read`].filter(Boolean).join(' / ')}
              </time>
            </div>

            <div class="fly-post-tag-row">
              {tags.slice(0, 4).map((tag) => (
                <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
              ))}
            </div>

            <h1>{frontmatter.title}</h1>

            {frontmatter.description && <p>{frontmatter.description}</p>}

            <div class="fly-post-article-actions">
              <a class="fly-post-action" href={canonicalUrl}>
                <span class="icon-[ph--link] size-4"></span>
                <span>链接</span>
              </a>
              <button class="fly-post-action cursor-pointer" type="button" data-copy-link={canonicalUrl}>
                <span class="icon-[ph--share-network] size-4"></span>
                <span>分享</span>
              </button>
            </div>
          </header>

          <aside class="fly-post-article-card" aria-label="文章详情">
            <p>Article details</p>
            <dl>
              <div>
                <dt>Author</dt>
                <dd>{displayAuthor}</dd>
              </div>
              <div>
                <dt>Published</dt>
                <dd>{publishedDate}</dd>
              </div>
              {updatedDate && (
                <div>
                  <dt>Updated</dt>
                  <dd>{updatedDate}</dd>
                </div>
              )}
              {(minutesRead || wordCount) && (
                <div>
                  <dt>Length</dt>
                  <dd>{[minutesRead && `${minutesRead} 分钟阅读`, POSTS_CONFIG.wordCountView && wordCount && `${wordCount} 字`].filter(Boolean).join(' / ')}</dd>
                </div>
              )}
            </dl>
          </aside>
        </div>

        <figure class="fly-post-article-media">
          {frontmatter.cover ? (
            <LqipImage
              src={frontmatter.cover}
              alt={frontmatter.title}
              width={1200}
              height={630}
              loading="eager"
              decoding="async"
              format="webp"
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="fly-post-cover-fallback min-h-[24rem]">
              <img src="/logo.svg" alt="" class="size-24" loading="eager" decoding="async" />
              <span>{tags[0] ?? 'Post'}</span>
            </div>
          )}
        </figure>
      </div>
    </section>

    <section class="fly-post-article-main">
      <div class="fly-post-container">
        <div class="fly-post-article-body-grid">
          <aside class="fly-post-article-rail" aria-label="文章目录信息">
            <p>{tags[0] ?? 'Article'}</p>
            <p>{publishedDate}</p>
            {minutesRead && <p>{minutesRead} min read</p>}
          </aside>

          <main>
            <Prose class="fly-post-article-body">
              <Content />
            </Prose>

            {frontmatter.license && (
              <section class="fly-post-license">
                <p>
                  Licensed under{' '}
                  {licenseLink ? (
                    <a href={licenseLink} target="_blank" rel="noreferrer">
                      {frontmatter.license}
                    </a>
                  ) : (
                    <span>{frontmatter.license}</span>
                  )}
                  .
                </p>
                <p>
                  永久链接：{' '}
                  <a href={canonicalUrl}>
                    {canonicalUrl}
                  </a>
                </p>
              </section>
            )}
          </main>
        </div>

        {(prev || next) && (
          <nav class="fly-post-adjacent" aria-label="文章导航">
            {next ? (
              <a href={`/posts/${next.id}`}>
                <span>{POSTS_CONFIG.prevPostText}</span>
                <strong>{next.data.title}</strong>
              </a>
            ) : (
              <div></div>
            )}

            {prev ? (
              <a href={`/posts/${prev.id}`} class="text-right">
                <span>{POSTS_CONFIG.nextPostText}</span>
                <strong>{prev.data.title}</strong>
              </a>
            ) : (
              <div></div>
            )}
          </nav>
        )}

        {relatedPosts.length > 0 && (
          <section class="fly-post-related">
            <div class="fly-post-section-head">
              <div>
                <p class="fly-post-section-label">Related reading</p>
                <h2>相关文章</h2>
              </div>
            </div>
            <div class="fly-post-related-grid">
              {relatedPosts.map((related) => {
                const relatedDate = related.data.updatedDate ?? related.data.pubDate
                return (
                  <a href={`/posts/${related.id}`}>
                    <p>{formatDate(relatedDate)}</p>
                    <h3>{related.data.title}</h3>
                    {related.data.description && <span>{related.data.description}</span>}
                  </a>
                )
              })}
            </div>
          </section>
        )}

        <section class="fly-post-comments">
          <Comment id={post.id} title={frontmatter.title} />
        </section>
      </div>
    </section>
  </div>

  <script>
    document.querySelectorAll('[data-copy-link]').forEach((button) => {
      button.addEventListener('click', async () => {
        const url = button.getAttribute('data-copy-link')
        if (!url) return
        try {
          await navigator.clipboard.writeText(url)
          button.setAttribute('aria-label', '链接已复制')
        } catch {
          window.location.href = url
        }
      })
    })
  </script>
</Layout>
