---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import LqipImage from '~/components/base/LqipImage.astro'
import Pagination from '~/components/base/Pagination.astro'
import PostKindTabs from '~/components/posts/base/PostKindTabs.astro'
import { POSTS_CONFIG } from '~/config'
import { getAllPosts, getAllTags } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const sortedPosts = await getAllPosts()

  return paginate(sortedPosts, {
    pageSize: POSTS_CONFIG.postPageConfig.size,
  })
}

interface Props {
  page: Page<CollectionEntry<'posts'>>
}

const { page } = Astro.props
const { title } = POSTS_CONFIG
const [allPosts, tags] = await Promise.all([getAllPosts(), getAllTags()])

const isFirstPage = page.currentPage === 1
const featuredPost = isFirstPage ? page.data[0] : null
const sidePosts = isFirstPage ? page.data.slice(1, 5) : page.data.slice(0, 4)
const streamPosts = isFirstPage ? page.data.slice(1) : page.data
const topTags = Object.entries(tags)
  .sort(([, countA], [, countB]) => countB - countA)
  .slice(0, 9)
const tileAccents = ['verge-accent-mint', 'verge-accent-purple', 'verge-accent-yellow', 'verge-accent-pink', 'verge-accent-orange']
const pageDescription = page.currentPage === 1
  ? POSTS_CONFIG.description
  : `Ethan Young 的文章归档第 ${page.currentPage} 页，继续浏览前端开发、工程实践、工具配置、技术复盘和生活总结。`
---

<Layout {title} description={pageDescription} fullWidth>
  <div class="verge-shell">
    <section class="mx-auto w-full max-w-[88rem] px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
      <div class="border-b border-white/35 pb-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <p class="verge-kicker">文章 / 随笔 / 技术笔记</p>
          <PostKindTabs active="posts" />
        </div>

        <div class="mt-5 grid gap-5 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
          <div>
            <h1 class="verge-display text-[clamp(5rem,15vw,13rem)] leading-[0.76] tracking-normal">{title}</h1>
            <p class="verge-copy mt-4 max-w-[52rem] text-base sm:text-lg">{POSTS_CONFIG.introduce}</p>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <div class="verge-stat">
              <p class="verge-kicker text-white/48">文章</p>
              <p class="mt-2 text-3xl leading-none tracking-normal text-white">{allPosts.length}</p>
            </div>
            <div class="verge-stat">
              <p class="verge-kicker text-white/48">主题</p>
              <p class="mt-2 text-3xl leading-none tracking-normal text-white">{topTags.length}</p>
            </div>
            <div class="verge-stat">
              <p class="verge-kicker text-white/48">页码</p>
              <p class="mt-2 text-3xl leading-none tracking-normal text-white">{page.currentPage}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 border-b border-white/35 py-5">
        <a href="/posts" class="verge-pill verge-pill-active">全部文章 ({allPosts.length})</a>
        {topTags.map(([tag, count]) => (
          <a href={`/tags/${encodeURIComponent(tag)}`} class="verge-pill">
            <span>{tag}</span>
            <span class="opacity-60">({count})</span>
          </a>
        ))}
      </div>

      {featuredPost && (
        <section class="grid gap-5 border-b border-white/35 py-5 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.65fr)]">
          <a href={`/posts/${featuredPost.id}`} class="verge-card-link overflow-hidden p-0">
            <article class="grid h-full lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1fr)]">
              <div class="min-h-72 border-b border-white/35 bg-[var(--theme-surface-soft)] lg:border-b-0 lg:border-r">
                {featuredPost.data.cover ? (
                  <LqipImage
                    src={featuredPost.data.cover}
                    alt={featuredPost.data.title}
                    width={980}
                    height={720}
                    loading="eager"
                    decoding="async"
                    format="webp"
                    class="h-full min-h-72 w-full object-cover"
                  />
                ) : (
                  <div class="verge-accent-mint flex h-full min-h-72 items-end p-6">
                    <span class="font-display text-[clamp(4rem,10vw,8rem)] leading-[0.8] tracking-normal">01</span>
                  </div>
                )}
              </div>

              <div class="flex min-h-full flex-col justify-between gap-10 p-5 sm:p-7">
                <div>
                  <p class="verge-kicker text-white/52">重点文章</p>
                  <h2 class="verge-heading mt-4 text-[clamp(2.15rem,4.8vw,5rem)] leading-[0.92]">{featuredPost.data.title}</h2>
                  {featuredPost.data.description && (
                    <p class="verge-copy mt-5 text-base sm:text-lg">{featuredPost.data.description}</p>
                  )}
                </div>

                <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-white/58">
                  <span>{formatDate(featuredPost.data.updatedDate ?? featuredPost.data.pubDate, 'short')}</span>
                  {featuredPost.data.tags?.slice(0, 3).map((tag) => (
                    <span class="rounded-full border border-white/30 px-2 py-1">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          </a>

          <aside class="verge-card-soft p-5">
            <p class="verge-kicker">最新文章</p>
            <ul class="mt-4 divide-y divide-white/12">
              {sidePosts.map((post, index) => (
                <li class="py-4 first:pt-0 last:pb-0">
                  <a href={`/posts/${post.id}`} class="group grid gap-2 text-white no-underline">
                    <p class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-white/45">
                      {String(index + 2).padStart(2, '0')} / {formatDate(post.data.updatedDate ?? post.data.pubDate, 'dot')}
                    </p>
                    <h3 class="text-2xl font-black leading-tight tracking-normal transition-colors group-hover:text-[var(--theme-highlight)]">
                      {post.data.title}
                    </h3>
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        </section>
      )}

      <section class="py-6">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="verge-kicker">时间线</p>
            <h2 class="mt-2 text-[clamp(2rem,4.6vw,4.2rem)] font-black leading-[0.9] tracking-normal text-white">全部记录</h2>
          </div>
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-white/48">
            本页 {streamPosts.length} 篇
          </p>
        </div>

        {streamPosts.length > 0 ? (
          <div class="relative grid gap-4 md:pl-16 md:before:absolute md:before:left-7 md:before:top-2 md:before:h-[calc(100%-0.5rem)] md:before:w-px md:before:bg-white/25">
            {streamPosts.map((post, index) => (
              <article class="relative grid gap-3 md:grid-cols-[7rem_minmax(0,1fr)] md:gap-4">
                <time
                  datetime={formatDate(post.data.updatedDate ?? post.data.pubDate, 'iso')}
                  class="font-mono text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-white/48 md:-ml-16 md:pt-5"
                >
                  {formatDate(post.data.updatedDate ?? post.data.pubDate, 'dot')}
                </time>

                <a
                  href={`/posts/${post.id}`}
                  class:list={[
                    'verge-card-link grid overflow-hidden p-0',
                    post.data.cover ? 'md:grid-cols-[18rem_minmax(0,1fr)]' : tileAccents[index % tileAccents.length],
                  ]}
                >
                  {post.data.cover && (
                    <figure class="h-56 border-b border-white/35 bg-[var(--theme-surface-soft)] md:h-full md:min-h-56 md:border-b-0 md:border-r">
                      <LqipImage
                        src={post.data.cover}
                        alt={post.data.title}
                        width={520}
                        height={390}
                        loading="lazy"
                        decoding="async"
                        format="webp"
                        class="h-full w-full object-cover"
                      />
                    </figure>
                  )}

                  <div class="flex min-h-56 flex-col justify-between gap-6 p-5">
                    <div>
                      <p class="verge-kicker opacity-65">文章 {String(index + 1).padStart(2, '0')}</p>
                      <h3 class="verge-heading mt-3 text-[clamp(1.65rem,3vw,2.8rem)]">{post.data.title}</h3>
                      {post.data.description && <p class="mt-3 line-clamp-2 text-sm leading-6 opacity-72">{post.data.description}</p>}
                    </div>

                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="inline-flex rounded-full border border-current px-2 py-1 font-mono text-[0.68rem] uppercase leading-none tracking-[0.1em] opacity-75">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <p class="py-10 text-center text-white/58">暂无文章。</p>
        )}
      </section>

      <Pagination {page} baseUrl="/posts" class="mx-auto mt-8 max-w-4xl" />
    </section>
  </div>
</Layout>
