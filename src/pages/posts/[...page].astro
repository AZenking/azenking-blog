---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import LqipImage from '~/components/base/LqipImage.astro'
import Pagination from '~/components/base/Pagination.astro'
import PostKindTabs from '~/components/posts/base/PostKindTabs.astro'
import { POSTS_CONFIG } from '~/config'
import { getAllPosts, getAllTags } from '~/lib/data'
import { formatDate } from '~/lib/utils'
import Layout from '~/layouts/Layout.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const sortedPosts = await getAllPosts()

  return paginate(sortedPosts, {
    pageSize: POSTS_CONFIG.postPageConfig.size,
  })
}

interface Props {
  page: Page<CollectionEntry<'posts'>>
}

const { page } = Astro.props
const { title } = POSTS_CONFIG
const [allPosts, tags] = await Promise.all([getAllPosts(), getAllTags()])

const isFirstPage = page.currentPage === 1
const featuredPost = isFirstPage ? page.data[0] : null
const sidePosts = isFirstPage ? page.data.slice(1, 5) : page.data.slice(0, 4)
const streamPosts = isFirstPage ? page.data.slice(1) : page.data
const topTags = Object.entries(tags)
  .sort(([, countA], [, countB]) => countB - countA)
  .slice(0, 9)
const pageDescription = page.currentPage === 1
  ? POSTS_CONFIG.description
  : `Ethan Young 的文章归档第 ${page.currentPage} 页，继续浏览前端开发、工程实践、工具配置、技术复盘和生活总结。`
---

<Layout {title} description={pageDescription} fullWidth>
  <div class="fly-post-shell">
    <section class="fly-post-hero">
      <div class="fly-post-container">
        <div class="flex flex-col gap-4 pt-8 lg:flex-row lg:items-center lg:justify-between">
          <a href="/atom.xml" class="fly-post-rss">
            <span class="icon-[ri--rss-line] size-4"></span>
            <span>RSS Feed</span>
          </a>
          <PostKindTabs active="posts" />
        </div>

        <div class="mt-10 grid gap-8 pb-10 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
          <div class="max-w-4xl">
            <p class="fly-post-eyebrow">Ethan Young / Blog Archive</p>
            <h1 class="fly-post-page-title">{title}</h1>
            <p class="fly-post-hero-copy">{POSTS_CONFIG.introduce}</p>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <div class="fly-post-stat">
              <p>Articles</p>
              <strong>{allPosts.length}</strong>
            </div>
            <div class="fly-post-stat">
              <p>Topics</p>
              <strong>{topTags.length}</strong>
            </div>
            <div class="fly-post-stat">
              <p>Page</p>
              <strong>{page.currentPage}</strong>
            </div>
          </div>
        </div>

        <nav class="fly-post-channel-nav" aria-label="文章主题">
          <a href="/posts" class="fly-post-channel is-active">全部文章 ({allPosts.length})</a>
          {topTags.map(([tag, count]) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="fly-post-channel">
              <span>{tag}</span>
              <span>{count}</span>
            </a>
          ))}
        </nav>
      </div>

      {featuredPost && (
        <div class="fly-post-container">
          <section class="fly-post-lead">
            <a href={`/posts/${featuredPost.id}`} class="fly-post-lead-copy">
              <div class="fly-post-meta-line">
                <span>By {featuredPost.data.author ?? POSTS_CONFIG.author}</span>
                <span>{formatDate(featuredPost.data.updatedDate ?? featuredPost.data.pubDate, 'short')}</span>
              </div>
              <h2>{featuredPost.data.title}</h2>
              {featuredPost.data.description && <p>{featuredPost.data.description}</p>}
              <span class="fly-post-read-more">Read more -></span>
            </a>

            <a href={`/posts/${featuredPost.id}`} class="fly-post-lead-media" aria-label={`阅读 ${featuredPost.data.title}`}>
              {featuredPost.data.cover ? (
                <LqipImage
                  src={featuredPost.data.cover}
                  alt={featuredPost.data.title}
                  width={980}
                  height={720}
                  loading="eager"
                  decoding="async"
                  format="webp"
                  class="h-full min-h-[22rem] w-full object-cover"
                />
              ) : (
                <div class="fly-post-cover-fallback min-h-[22rem]">
                  <img src="/logo.svg" alt="" class="size-24" loading="eager" decoding="async" />
                  <span>01</span>
                </div>
              )}
            </a>
          </section>
        </div>
      )}
    </section>

    <section class="fly-post-archive">
      <div class="fly-post-container">
        {sidePosts.length > 0 && (
          <aside class="fly-post-latest">
            <div>
              <p class="fly-post-section-label">Latest dispatches</p>
              <h2>最新文章</h2>
            </div>
            <div class="fly-post-latest-list">
              {sidePosts.map((post, index) => (
                <a href={`/posts/${post.id}`} class="fly-post-latest-item">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <div>
                    <p>{formatDate(post.data.updatedDate ?? post.data.pubDate, 'dot')}</p>
                    <h3>{post.data.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </aside>
        )}

        <section class="fly-post-stream">
          <div class="fly-post-section-head">
            <div>
              <p class="fly-post-section-label">Article stream</p>
              <h2>全部记录</h2>
            </div>
            <p>本页 {streamPosts.length} 篇</p>
          </div>

          {streamPosts.length > 0 ? (
            <div class="fly-post-card-grid">
              {streamPosts.map((post, index) => (
                <article>
                  <a href={`/posts/${post.id}`} class="fly-post-card">
                    <div class="fly-post-card-media">
                      {post.data.cover ? (
                        <LqipImage
                          src={post.data.cover}
                          alt={post.data.title}
                          width={720}
                          height={440}
                          loading="lazy"
                          decoding="async"
                          format="webp"
                          class="h-full w-full object-cover"
                        />
                      ) : (
                        <div class="fly-post-cover-fallback">
                          <img src="/logo.svg" alt="" class="size-16" loading="lazy" decoding="async" />
                          <span>{String(index + 1).padStart(2, '0')}</span>
                        </div>
                      )}
                    </div>

                    <div class="fly-post-card-body">
                      <div class="fly-post-meta-line">
                        <span>By {post.data.author ?? POSTS_CONFIG.author}</span>
                        <span>{formatDate(post.data.updatedDate ?? post.data.pubDate, 'short')}</span>
                      </div>
                      <h3>{post.data.title}</h3>
                      {post.data.description && <p>{post.data.description}</p>}
                      {post.data.tags && post.data.tags.length > 0 && (
                        <div class="fly-post-tag-row">
                          {post.data.tags.slice(0, 3).map((tag) => (
                            <span>{tag}</span>
                          ))}
                        </div>
                      )}
                      <span class="fly-post-read-more">Read more -></span>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <p class="fly-post-empty">暂无文章。</p>
          )}
        </section>

        <Pagination {page} baseUrl="/posts" class="mx-auto mt-12 max-w-4xl" />
      </div>
    </section>
  </div>
</Layout>
