---
import { PROJECTS_CONFIG } from '~/config'
import { getAllProjects } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'

const { title, introduce } = PROJECTS_CONFIG
const projects = await getAllProjects()

const resolveHref = (project: { data: { website: string; githubUrl: string } }) =>
  project.data.website || project.data.githubUrl || '/projects'

const isExternal = (href: string) => /^https?:\/\//i.test(href) || href.startsWith('//')
---

<Layout title={title} description={PROJECTS_CONFIG.description} fullWidth>
  <div class="projects-page">
    <header class="projects-header">
      <h1>{title}</h1>
      <p class="projects-desc">{introduce}</p>
      <p class="projects-tagline">{projects.length} 个项目 · 持续迭代</p>
    </header>

    <section class="projects-list-wrap">
      <ul class="projects-list">
        {projects.map((project, index) => {
          const href = resolveHref(project)
          const external = isExternal(href)
          const { star, fork, type } = project.data
          const metaParts: string[] = []
          if (type) metaParts.push(type)
          if (star != null) metaParts.push(`★ ${star}`)
          if (fork != null) metaParts.push(`⑂ ${fork}`)

          return (
            <li class="projects-list-item" data-project-reveal style={`--reveal-index: ${index}`}>
              <a
                href={href}
                class="projects-list-link"
                target={external ? '_blank' : undefined}
                rel={external ? 'noreferrer' : undefined}
              >
                <span class="projects-title">{project.data.name}</span>
                {project.data.description && (
                  <span class="projects-description">{project.data.description}</span>
                )}
                {metaParts.length > 0 && (
                  <span class="projects-meta">{metaParts.join(' · ')}</span>
                )}
              </a>
            </li>
          )
        })}
      </ul>

      {projects.length === 0 && <p class="projects-empty">暂无项目。</p>}
    </section>
  </div>
</Layout>

<style>
  .projects-page {
    width: 100%;
    margin-inline: auto;
    padding: clamp(3.5rem, 8vw, 6rem) 1.25rem 3rem;
    color: var(--article-ink);
    background:
      linear-gradient(180deg, rgb(128 122 113 / 0.035), transparent 18rem),
      var(--article-paper);
  }

  .projects-header {
    width: min(100%, 48rem);
    margin-inline: auto;
    margin-bottom: clamp(2.5rem, 5vw, 3.75rem);
  }

  .projects-header h1 {
    margin: 0 0 0.4em;
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .projects-desc {
    margin: 0 0 1.25rem;
    color: var(--article-soft);
    font-family: var(--font-editorial);
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.5;
    text-wrap: balance;
  }

  .projects-tagline {
    margin: 0;
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .projects-list-wrap {
    width: min(100%, 48rem);
    margin-inline: auto;
  }

  .projects-list {
    list-style: none;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .projects-list-item {
    margin: 0;
  }

  :global(html.projects-reveal-ready) .projects-list-item {
    opacity: 0;
    transform: translateY(0.75rem);
    transition:
      opacity 480ms ease,
      transform 480ms ease;
    transition-delay: calc(var(--reveal-index, 0) * 55ms);
  }

  :global(html.projects-reveal-ready) .projects-list-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .projects-list-link {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 0 1.15rem;
    color: var(--article-ink);
    text-decoration: none;
    border-block-end: 1px solid var(--article-rule);
    transition: opacity 200ms ease;
  }

  .projects-list-link:hover {
    opacity: 0.72;
  }

  .projects-list-link:focus-visible {
    outline: 1px solid var(--article-accent);
    outline-offset: 0.35rem;
  }

  .projects-title {
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(1.2rem, 2.2vw, 1.4rem);
    font-weight: 600;
    line-height: 1.3;
    text-wrap: balance;
  }

  .projects-description {
    display: -webkit-box;
    overflow: hidden;
    color: var(--article-soft);
    font-family: var(--font-editorial);
    font-size: 0.95rem;
    line-height: 1.6;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .projects-meta {
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    opacity: 0.85;
  }

  .projects-empty {
    color: var(--article-soft);
  }

  @media (max-width: 760px) {
    .projects-page {
      padding-top: 3rem;
    }

    .projects-header {
      margin-bottom: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .projects-list-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const initProjectsReveal = () => {
    const revealItems = document.querySelectorAll<HTMLElement>('[data-project-reveal]')
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (reduceMotion || !('IntersectionObserver' in window)) {
      document.documentElement.classList.remove('projects-reveal-ready')
      revealItems.forEach((item) => item.classList.add('is-visible'))
      return
    }

    document.documentElement.classList.add('projects-reveal-ready')

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return
          entry.target.classList.add('is-visible')
          observer.unobserve(entry.target)
        })
      },
      {
        rootMargin: '0px 0px -8% 0px',
        threshold: 0.12,
      },
    )

    revealItems.forEach((item) => observer.observe(item))
  }

  initProjectsReveal()
  document.addEventListener('astro:page-load', initProjectsReveal)
</script>
