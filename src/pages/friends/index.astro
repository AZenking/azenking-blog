---
import { FRIEND_LINKS, FRIENDS_CONFIG, SOCIAL_LINKS } from '~/config'
import Layout from '~/layouts/Layout.astro'

const { title, description, introduce } = FRIENDS_CONFIG
const githubUrl = SOCIAL_LINKS.find((social) => social.name.toLowerCase() === 'github')?.url

const getHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '')
  } catch {
    return url
  }
}

const friendItems = FRIEND_LINKS.map((friend) => ({
  ...friend,
  host: getHost(friend.url),
  summary: friend.description?.trim() || '分享技术、设计或日常观察。',
  initials: friend.name.trim().slice(0, 1).toUpperCase(),
}))

const totalTags = friendItems.reduce((sum, friend) => sum + (friend.tags?.length ?? 0), 0)
const featuredFriend = friendItems[0]
---

<Layout {title} {description} fullWidth>
  <div class="min-h-screen bg-[#f4f4f0] text-black dark:bg-[#242423] dark:text-white">
    <section class="w-full px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
      <div class="border-b border-black pb-8 dark:border-white/35">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Circle</p>
            <h1 class="mt-4 text-[clamp(2.5rem,6vw,4.75rem)] leading-[1.02] tracking-[-0.06em]">{title}</h1>
            <p class="mt-5 max-w-[48rem] text-base leading-8 text-black/66 sm:text-lg dark:text-white/66">{introduce}</p>
          </div>

          <div class="grid w-full max-w-xl grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Links</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{friendItems.length}</p>
            </div>
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Tags</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{totalTags}</p>
            </div>
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Exchange</p>
              <p class="mt-2 text-2xl leading-none tracking-[-0.05em]">{githubUrl ? 'Open' : 'Closed'}</p>
            </div>
          </div>
        </div>
      </div>

      {featuredFriend && (
        <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_24rem]">
          <article class="overflow-hidden rounded-lg border border-black bg-white dark:border-white/35 dark:bg-black">
            <div class="border-b border-black px-6 py-6 dark:border-white/35">
              <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/48">Featured friend</p>
              <div class="mt-4 flex items-start gap-4">
                <div class="inline-flex size-14 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-black bg-[#ff90e8] text-lg text-black dark:border-white/35">
                  {featuredFriend.avatar ? (
                    <img src={featuredFriend.avatar} alt={featuredFriend.name} class="size-full object-cover" loading="lazy" decoding="async" />
                  ) : (
                    <span>{featuredFriend.initials}</span>
                  )}
                </div>
                <div class="min-w-0">
                  <h2 class="text-[clamp(1.8rem,3vw,3rem)] leading-[1.04] tracking-[-0.05em]">{featuredFriend.name}</h2>
                  <p class="mt-2 text-sm uppercase tracking-[0.12em] text-black/48 dark:text-white/48">{featuredFriend.host}</p>
                </div>
              </div>
            </div>

            <div class="grid gap-5 p-6">
              <p class="max-w-3xl text-base leading-8 text-black/68 dark:text-white/68">{featuredFriend.summary}</p>

              {featuredFriend.tags && featuredFriend.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {featuredFriend.tags.map((tag) => (
                    <span class="inline-flex rounded-sm border border-black px-3 py-2 text-sm dark:border-white/35">{tag}</span>
                  ))}
                </div>
              )}

              <div>
                <a
                  href={featuredFriend.url}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 rounded-sm bg-black px-4 py-2.5 text-sm text-white no-underline transition-all hover:-translate-x-px hover:-translate-y-px hover:shadow-[2px_2px_0_0_#000] dark:bg-white dark:text-black dark:hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]"
                >
                  <span>Visit site</span>
                  <span class="icon-[mdi--arrow-top-right] size-4" />
                </a>
              </div>
            </div>
          </article>

          <aside class="rounded-lg border border-black bg-white p-5 dark:border-white/35 dark:bg-black">
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Link exchange</p>
            <p class="mt-4 text-sm leading-7 text-black/64 dark:text-white/64">
              如果你也在持续写作、做产品或者记录日常，欢迎互换友链。
            </p>
            {githubUrl && (
              <a
                href={githubUrl}
                target="_blank"
                rel="noreferrer"
                class="mt-5 inline-flex items-center gap-2 text-sm text-[#d64b2a] no-underline hover:text-[#b22f14]"
              >
                <span>Contact via GitHub</span>
                <span class="icon-[mdi--arrow-top-right] size-4" />
              </a>
            )}

            <div class="mt-6 border-t border-black/12 pt-5 dark:border-white/12">
              <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Index</p>
              <ul class="mt-3 space-y-3">
                {friendItems.map((friend) => (
                  <li class="flex items-center justify-between gap-4">
                    <span class="truncate text-sm">{friend.name}</span>
                    <span class="text-[0.7rem] uppercase tracking-[0.12em] text-black/45 dark:text-white/45">{friend.host}</span>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        </div>
      )}

      <section class="mt-14 border-t border-black pt-8 dark:border-white/35">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Directory</p>
            <h2 class="mt-3 text-[clamp(1.9rem,4vw,3.15rem)] leading-[1.04] tracking-[-0.05em]">Friends & Feeds</h2>
          </div>
          <p class="max-w-xl text-sm leading-7 text-black/62 dark:text-white/62">
            A small directory of sites worth visiting, with the same crisp bordered card system used across the rest of the archive.
          </p>
        </div>

        {friendItems.length > 0 ? (
          <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
            {friendItems.map((friend) => (
              <a
                href={friend.url}
                target="_blank"
                rel="noreferrer"
                class="group rounded-lg border border-black bg-white p-6 text-black no-underline transition-all duration-200 ease-out hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[3px_3px_0_0_#000] dark:border-white/35 dark:bg-black dark:text-white dark:hover:shadow-[3px_3px_0_0_rgba(255,255,255,0.35)]"
              >
                <div class="flex items-start gap-4">
                  <div class="inline-flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-black bg-[#ece9df] dark:border-white/35 dark:bg-[#111]">
                    {friend.avatar ? (
                      <img src={friend.avatar} alt={friend.name} class="size-full object-cover" loading="lazy" decoding="async" />
                    ) : (
                      <span>{friend.initials}</span>
                    )}
                  </div>

                  <div class="min-w-0 flex-1">
                    <div class="flex items-start justify-between gap-3">
                      <h3 class="truncate text-2xl leading-tight tracking-[-0.04em]">{friend.name}</h3>
                      <span class="inline-flex size-9 items-center justify-center rounded-md border border-black transition-all duration-200 group-hover:-translate-x-px group-hover:-translate-y-px group-hover:shadow-[2px_2px_0_0_#000] dark:border-white/35 dark:group-hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]">
                        ↗
                      </span>
                    </div>
                    <p class="mt-2 text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">{friend.host}</p>
                    <p class="mt-3 text-sm leading-7 text-black/68 dark:text-white/68">{friend.summary}</p>
                  </div>
                </div>

                {friend.tags && friend.tags.length > 0 && (
                  <div class="mt-5 flex flex-wrap gap-2">
                    {friend.tags.map((tag) => (
                      <span class="inline-flex rounded-sm border border-black px-2 py-1 text-xs uppercase tracking-[0.1em] dark:border-white/35">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        ) : (
          <p class="text-sm text-black/56 dark:text-white/56">No friend links available yet.</p>
        )}
      </section>
    </section>
  </div>
</Layout>
