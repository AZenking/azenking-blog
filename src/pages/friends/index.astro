---
import { FRIEND_LINKS, FRIENDS_CONFIG } from '~/config'
import Layout from '~/layouts/Layout.astro'

const { title, introduce } = FRIENDS_CONFIG

const getHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '')
  } catch {
    return url
  }
}
---

<Layout title={title} description={FRIENDS_CONFIG.description}>
  <div class="antfu-page">
    <h1>{title}</h1>
    <p class="antfu-desc">{introduce}</p>

    <ul class="antfu-list">
      {FRIEND_LINKS.map((friend) => (
        <li class="antfu-friend">
          <a href={friend.url} class="antfu-friend-link" target="_blank" rel="noreferrer">
            <span>{friend.name}</span>
            <span class="antfu-host">{getHost(friend.url)} ↗</span>
          </a>
          {friend.description && <p class="antfu-friend-desc">{friend.description}</p>}
        </li>
      ))}
    </ul>

    {FRIEND_LINKS.length === 0 && <p>暂无友链。</p>}
  </div>
</Layout>

<style>
  .antfu-page { max-width: var(--layout-width); margin-inline: auto; padding: 4rem 1rem 2rem; }
  .antfu-page h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5em; }
  .antfu-desc { opacity: var(--opacity-muted); margin: 0 0 2rem; }
  .antfu-list { list-style: none; padding: 0; margin: 0; }
  .antfu-friend { padding: 0.6em 0; }
  .antfu-friend-link { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; text-decoration: none; color: var(--theme-text); transition: opacity 200ms ease; }
  .antfu-friend-link:hover { opacity: var(--opacity-secondary); }
  .antfu-friend-link span:first-child { font-weight: 600; }
  .antfu-host { flex-shrink: 0; font-size: 0.8125rem; opacity: var(--opacity-muted); }
  .antfu-friend-desc { margin: 0.25em 0 0; opacity: var(--opacity-muted); font-size: 0.875rem; }
</style>
