---
import { FRIEND_LINKS, FRIENDS_CONFIG } from '~/config'
import Layout from '~/layouts/Layout.astro'

const { title, introduce } = FRIENDS_CONFIG

const getHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '')
  } catch {
    return url
  }
}
---

<Layout title={title} description={FRIENDS_CONFIG.description} fullWidth>
  <div class="magi-page">
    <h1>{title}</h1>
    <p class="magi-desc">{introduce}</p>

    <ul class="magi-list">
      {FRIEND_LINKS.map((friend) => (
        <li class="magi-friend">
          <a href={friend.url} class="magi-friend-link" target="_blank" rel="noreferrer">
            <span>{friend.name}</span>
            <span class="magi-host">{getHost(friend.url)} ↗</span>
          </a>
          {friend.description && <p class="magi-friend-desc">{friend.description}</p>}
        </li>
      ))}
    </ul>

    {FRIEND_LINKS.length === 0 && <p>暂无友链。</p>}
  </div>
</Layout>

<style>
  .magi-page {
    width: 100%;
    margin-inline: auto;
    padding-block: clamp(3.5rem, 8vw, 6rem) 3rem;
    padding-inline: max(1.25rem, calc((100% - var(--content-width)) / 2));
    color: var(--article-ink);
    background:
      linear-gradient(180deg, rgb(128 122 113 / 0.035), transparent 18rem),
      var(--article-paper);
  }

  .magi-page h1 {
    margin: 0 0 0.4em;
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .magi-desc {
    margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
    color: var(--article-soft);
    font-family: var(--font-editorial);
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.5;
    text-wrap: balance;
  }

  .magi-list { list-style: none; padding: 0; margin: 0; }

  .magi-friend {
    padding: 1rem 0 1.15rem;
    border-block-end: 1px solid var(--article-rule);
  }

  .magi-friend-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(1.2rem, 2.2vw, 1.4rem);
    font-weight: 500;
    line-height: 1.3;
    text-wrap: balance;
    text-decoration: none;
    transition: opacity 200ms ease;
  }

  .magi-friend-link:hover { opacity: 1; color: var(--brand); }

  .magi-host {
    flex-shrink: 0;
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    opacity: 0.85;
  }

  .magi-friend-desc {
    margin: 0.35em 0 0;
    color: var(--article-soft);
    font-family: var(--font-editorial);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 760px) {
    .magi-page { padding-top: 3rem; }
  }
</style>
