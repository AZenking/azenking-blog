---
import { FRIEND_LINKS, FRIENDS_CONFIG, SOCIAL_LINKS } from '~/config'
import Layout from '~/layouts/Layout.astro'

const { title, description, introduce } = FRIENDS_CONFIG
const githubUrl = SOCIAL_LINKS.find((social) => social.name.toLowerCase() === 'github')?.url

const getHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '')
  } catch {
    return url
  }
}

const friendItems = FRIEND_LINKS.map((friend) => ({
  ...friend,
  host: getHost(friend.url),
  summary: friend.description?.trim() || '分享技术、设计或日常观察。',
  initials: friend.name.trim().slice(0, 1).toUpperCase(),
}))
---

<Layout {title} {description}>
  <div class="px-6 py-12 sm:px-8 sm:py-14">
    <section class="mx-auto max-w-3xl">
      <p class="text-sm uppercase tracking-[0.16em] text-muted-foreground">Friends</p>
      <h1 class="mt-3 font-sans text-[clamp(2.1rem,5vw,3.4rem)] font-semibold tracking-tight text-foreground">{title}</h1>
      <p class="mt-5 max-w-[60ch] text-base leading-8 text-muted-foreground">{introduce}</p>
      <p class="mt-6 text-xs uppercase tracking-[0.14em] text-muted-foreground">Current Links · {friendItems.length}</p>
    </section>

    <section class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6">
      {
        friendItems.map((friend) => (
          <a
            href={friend.url}
            target="_blank"
            rel="noreferrer"
            class="group rounded-3xl border border-border/55 bg-background/72 p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-border/90 hover:bg-background/92 sm:p-7"
          >
            <div class="flex items-start gap-4">
              <div class="inline-flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-full border border-border/60 bg-muted/20 text-sm font-medium text-muted-foreground">
                {
                  friend.avatar ? (
                    <img src={friend.avatar} alt={friend.name} class="size-full object-cover" loading="lazy" decoding="async" />
                  ) : (
                    <span>{friend.initials}</span>
                  )
                }
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-2">
                  <h2 class="truncate font-sans text-xl font-medium tracking-tight text-foreground">{friend.name}</h2>
                  <span class="icon-[mdi--arrow-top-right] mt-1 size-4 shrink-0 text-muted-foreground transition-colors group-hover:text-foreground" />
                </div>
                <p class="mt-1 text-xs uppercase tracking-[0.12em] text-muted-foreground">{friend.host}</p>
              </div>
            </div>

            <p class="mt-5 text-sm leading-7 text-muted-foreground">{friend.summary}</p>

            {friend.tags && friend.tags.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {friend.tags.map((tag) => (
                  <span class="rounded-full border border-border/55 px-3 py-1 text-xs tracking-[0.08em] text-muted-foreground">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))
      }
    </section>

    {githubUrl && (
      <section class="mx-auto mt-14 max-w-5xl border-t border-border/55 pt-7">
        <p class="text-sm leading-7 text-muted-foreground">
          如果你也在写作或分享，欢迎交换友链。可以通过
          <a
            href={githubUrl}
            target="_blank"
            rel="noreferrer"
            class="ml-1 inline-flex items-center gap-1 text-foreground underline decoration-border/70 underline-offset-4 transition-colors hover:text-foreground/75"
          >
            GitHub
            <span class="icon-[mdi--arrow-top-right] size-3.5" />
          </a>
          联系我。
        </p>
      </section>
    )}
  </div>
</Layout>
