---
import MasonryPhotoFeed from '~/components/photos/MasonryPhotoFeed'
import { PHOTOS_CONFIG } from '~/config'
import { PhotosList } from '~/lib/photos'
import Layout from '~/layouts/Layout.astro'

const { title, introduce } = PHOTOS_CONFIG

const galleryPhotos = PhotosList.flatMap((album) =>
  album.photos.map((photo, index) => ({
    src: typeof photo.src === 'string' ? photo.src : photo.src.src,
    alt: photo.alt,
    description: photo.description ?? `${album.title} / Frame ${String(index + 1).padStart(2, '0')}`,
    album: album.title,
    date: album.date,
    width: photo.width,
    height: photo.height,
  }))
)

const albumCount = PhotosList.length
const photoCount = galleryPhotos.length
---

<Layout title={title} description={PHOTOS_CONFIG.description} fullWidth>
  <div class="photos-page">
    <header class="photos-header">
      <h1>{title}</h1>
      <p class="photos-desc">{introduce}</p>
      <p class="photos-tagline">{photoCount} 张照片 · {albumCount} 个相册</p>
    </header>

    <div class="photos-feed">
      <MasonryPhotoFeed client:load photos={galleryPhotos} />
    </div>
  </div>
</Layout>

<style>
  .photos-page {
    width: 100%;
    margin-inline: auto;
    padding: clamp(3.5rem, 8vw, 6rem) 1.25rem 3rem;
    color: var(--article-ink);
    background:
      linear-gradient(180deg, rgb(128 122 113 / 0.035), transparent 18rem),
      var(--article-paper);
  }

  .photos-header {
    width: min(100%, 48rem);
    margin-inline: auto;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .photos-header h1 {
    margin: 0 0 0.4em;
    color: var(--article-ink);
    font-family: var(--font-editorial);
    font-size: clamp(2.5rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .photos-desc {
    margin: 0 0 1.25rem;
    color: var(--article-soft);
    font-family: var(--font-editorial);
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.5;
    text-wrap: balance;
  }

  .photos-tagline {
    margin: 0;
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .photos-feed {
    width: min(100%, 48rem);
    margin-inline: auto;
  }
</style>
