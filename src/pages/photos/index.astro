---
import { PHOTOS_CONFIG } from '~/config'
import { PhotosList } from '~/lib/photos'
import Layout from '~/layouts/Layout.astro'
import MasonryPhotoFeed from '~/components/photos/MasonryPhotoFeed'

const { title, description, introduce } = PHOTOS_CONFIG

const galleryPhotos = PhotosList.flatMap((album) =>
  album.photos.map((photo, index) => ({
    src: typeof photo.src === 'string' ? photo.src : photo.src.src,
    alt: photo.alt,
    description: photo.description ?? `${album.title} · 生活片段 ${String(index + 1).padStart(2, '0')}`,
    album: album.title,
    date: album.date,
    width: photo.width,
    height: photo.height,
  }))
)

const totalAlbums = PhotosList.length
const totalPhotos = galleryPhotos.length
const latestAlbum = PhotosList[0]
const featuredPhoto = galleryPhotos[0]
---

<Layout {title} {description} fullWidth>
  <div class="min-h-screen bg-[#f4f4f0] text-black dark:bg-[#242423] dark:text-white">
    <section class="w-full px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
      <div class="border-b border-black pb-8 dark:border-white/35">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Photo Journal</p>
            <h1 class="mt-4 text-[clamp(2.5rem,6vw,4.75rem)] leading-[1.02] tracking-[-0.06em]">{title}</h1>
            <p class="mt-5 max-w-[48rem] text-base leading-8 text-black/66 sm:text-lg dark:text-white/66">
              {introduce}
            </p>
          </div>

          <div class="grid w-full max-w-xl grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Albums</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{totalAlbums}</p>
            </div>
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Frames</p>
              <p class="mt-2 text-3xl leading-none tracking-[-0.05em]">{totalPhotos}</p>
            </div>
            <div class="rounded-lg border border-black bg-white px-4 py-4 dark:border-white/35 dark:bg-black">
              <p class="text-[0.72rem] uppercase tracking-[0.12em] text-black/48 dark:text-white/48">Updated</p>
              <p class="mt-2 text-2xl leading-none tracking-[-0.05em]">{latestAlbum?.date ?? 'Soon'}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-sm bg-black px-3 py-2 text-sm text-white dark:bg-white dark:text-black">
          All frames ({totalPhotos})
        </span>
        {PhotosList.map((album) => (
          <span class="inline-flex items-center gap-2 rounded-sm border border-black bg-white px-3 py-2 text-sm text-black dark:border-white/35 dark:bg-black dark:text-white">
            <span>{album.title}</span>
            <span class="text-black/50 dark:text-white/50">({album.photos.length})</span>
          </span>
        ))}
      </div>

      <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_24rem]">
        {featuredPhoto && (
          <article class="overflow-hidden rounded-lg border border-black bg-white dark:border-white/35 dark:bg-black">
            <div class="aspect-[4/3] overflow-hidden border-b border-black bg-[#ece9df] dark:border-white/35 dark:bg-[#111]">
              <img
                src={featuredPhoto.src}
                alt={featuredPhoto.alt}
                width={featuredPhoto.width}
                height={featuredPhoto.height}
                class="h-full w-full object-cover"
                loading="eager"
                decoding="async"
              />
            </div>
            <div class="grid gap-3 p-6">
              <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/48">Featured frame</p>
              <h2 class="text-[clamp(1.8rem,3vw,3rem)] leading-[1.04] tracking-[-0.05em]">
                {featuredPhoto.description ?? featuredPhoto.alt}
              </h2>
              <p class="text-base leading-8 text-black/66 dark:text-white/66">
                Click any frame below to open the lightbox. The page keeps the same editorial shell as the rest of the site, but
                lets the photography stay dominant.
              </p>
              <p class="text-sm uppercase tracking-[0.12em] text-black/48 dark:text-white/48">
                {[featuredPhoto.album, featuredPhoto.date].filter(Boolean).join(' · ')}
              </p>
            </div>
          </article>
        )}

        <aside class="rounded-lg border border-black bg-white p-5 dark:border-white/35 dark:bg-black">
          <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Recent sets</p>
          <ul class="mt-4 divide-y divide-black/12 dark:divide-white/12">
            {PhotosList.map((album) => (
              <li class="py-4 first:pt-0 last:pb-0">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="text-2xl leading-tight tracking-[-0.04em]">{album.title}</h3>
                    <p class="mt-2 text-sm leading-7 text-black/64 dark:text-white/64">{album.description}</p>
                  </div>
                  <div class="rounded-md border border-black px-3 py-2 text-right text-sm dark:border-white/35">
                    <p>{album.photos.length}</p>
                    <p class="mt-1 text-[0.68rem] uppercase tracking-[0.12em] text-black/45 dark:text-white/45">frames</p>
                  </div>
                </div>
                <p class="mt-3 text-sm uppercase tracking-[0.12em] text-black/45 dark:text-white/45">{album.date}</p>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <section class="mt-14 border-t border-black pt-8 dark:border-white/35">
        <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-[0.72rem] uppercase tracking-[0.14em] text-black/48 dark:text-white/45">Gallery</p>
            <h2 class="mt-3 text-[clamp(1.9rem,4vw,3.15rem)] leading-[1.04] tracking-[-0.05em]">Recent Frames</h2>
          </div>
          <p class="max-w-xl text-sm leading-7 text-black/62 dark:text-white/62">
            A running archive of daily fragments, loaded progressively as you scroll. Open any image to browse the sequence in a
            dedicated lightbox.
          </p>
        </div>

        {galleryPhotos.length > 0 ? (
          <MasonryPhotoFeed photos={galleryPhotos} initialCount={9} loadStep={6} client:visible />
        ) : (
          <p class="text-sm text-black/56 dark:text-white/56">No photos yet, wait for me to return.</p>
        )}
      </section>
    </section>
  </div>
</Layout>
