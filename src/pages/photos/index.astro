---
import { PHOTOS_CONFIG } from '~/config'
import Layout from '~/layouts/Layout.astro'
import PageTitle from '~/components/base/PageTitle.astro'
import { PhotosList } from '~/lib/photos'
import MasonryPhotoFeed from '~/components/photos/MasonryPhotoFeed'

const { title, description, introduce } = PHOTOS_CONFIG
const totalPhotos = PhotosList.reduce((sum, album) => sum + album.photos.length, 0)

const galleryPhotos = PhotosList.flatMap((album) =>
  album.photos.map((photo, index) => ({
    src: typeof photo.src === 'string' ? photo.src : photo.src.src,
    alt: photo.alt,
    description: photo.description ?? `${album.title} · 生活片段 ${String(index + 1).padStart(2, '0')}`,
    album: album.title,
    date: album.date,
    width: photo.width,
    height: photo.height,
  }))
)
---

<Layout {title} {description}>
  <div class="px-6 py-10 sm:px-8 sm:py-12">
    <PageTitle {title} {introduce} />

    <section class="mt-8 rounded-3xl border border-border/55 bg-background/80 p-5 sm:p-7">
      <div class="mb-8 max-w-3xl">
        <p class="text-sm uppercase tracking-[0.14em] text-muted-foreground">Photo Stream</p>
        <h2 class="mt-3 font-sans text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">瀑布流浏览 · 逐步加载 · 全屏查看</h2>
        <p class="mt-3 text-sm leading-7 text-muted-foreground sm:text-base">
          当前共 {totalPhotos} 张照片。向下滚动会自动加载更多，点击任意图片可进入 Lightbox 查看大图和图片说明。
        </p>
      </div>

      {galleryPhotos.length > 0 ? (
        <MasonryPhotoFeed photos={galleryPhotos} client:load />
      ) : (
        <p class="text-sm text-muted-foreground">No photos yet, wait for me to return, OvO</p>
      )}
    </section>
  </div>
</Layout>
