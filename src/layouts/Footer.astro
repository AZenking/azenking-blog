---
import { SITE, SOCIAL_LINKS } from '~/config'

const START_YEAR = 2025
const currentYear = new Date().getFullYear()
const yearDisplay = currentYear > START_YEAR ? `${START_YEAR}–${currentYear}` : `${START_YEAR}`
---

<footer class="apple-ui border-t border-border/55 bg-background/76 backdrop-blur supports-[backdrop-filter]:bg-background/62">
  <div class="global-layout-width mx-auto flex flex-col gap-4 px-4 py-7 text-xs text-muted-foreground sm:flex-row sm:items-center sm:justify-between sm:px-6 sm:py-8">
    <p class="tracking-[0.015em]">© {yearDisplay} {SITE.author}. All rights reserved.</p>

    <div class="flex flex-wrap items-center gap-4 sm:gap-5">
      {SOCIAL_LINKS.map((item) => (
        <a href={item.url} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 transition-colors hover:text-foreground/90">
          <span class={item.icon}></span>
          <span class="capitalize">{item.name}</span>
        </a>
      ))}

      <a href="/atom.xml" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 transition-colors hover:text-foreground/90">
        <span class="icon-[ri--rss-line] text-[14px]"></span>
        <span>RSS</span>
      </a>
    </div>
  </div>
</footer>
