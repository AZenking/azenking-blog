---
import { FOOTER_LINKS, SITE, SOCIAL_LINKS } from '~/config'

const START_YEAR = 2025
const currentYear = new Date().getFullYear()
const yearDisplay = currentYear > START_YEAR ? `${START_YEAR}–${currentYear}` : `${START_YEAR}`
const githubLink = SOCIAL_LINKS.find((item) => item.name === 'github')
---

<footer class="magi-footer">
  <div class="magi-footer-inner">
    <span class="magi-footer-copy">{yearDisplay} © {SITE.author}</span>
    <nav class="magi-footer-links" aria-label="页脚导航">
      {githubLink && <a href={githubLink.url} target="_blank" rel="noreferrer">GitHub</a>}
      <a href="/atom.xml">RSS</a>
      {
        FOOTER_LINKS.map((link) => (
          <a href={link.url}>{link.name}</a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .magi-footer {
    width: min(100%, 48rem);
    margin-inline: auto;
    padding: 2rem 1.25rem 2.5rem;
    border-block-start: 1px solid var(--article-rule);
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .magi-footer-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .magi-footer-copy {
    color: var(--article-soft);
  }

  .magi-footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
  }

  .magi-footer-links a {
    color: var(--article-soft);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .magi-footer-links a:hover {
    color: var(--article-ink);
  }

  .magi-footer-links a:focus-visible {
    outline: 1px solid var(--article-accent);
    outline-offset: 0.35rem;
  }
</style>
