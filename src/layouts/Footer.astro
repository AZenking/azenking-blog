---
import { FOOTER_LINKS, SITE, SOCIAL_LINKS } from '~/config'

const START_YEAR = 2025
const currentYear = new Date().getFullYear()
const yearDisplay = currentYear > START_YEAR ? `${START_YEAR}–${currentYear}` : `${START_YEAR}`
const cleanDescription = SITE.description.replace(/^👋\s*/, '')
const githubLink = SOCIAL_LINKS.find((item) => item.name === 'github')

const primaryLinks = [
  { name: '首页', url: '/' },
  { name: '文章', url: '/posts' },
  { name: '项目', url: '/projects' },
  { name: '标签', url: '/tags' },
]

const secondaryLinks = [
  ...FOOTER_LINKS.map((item) => ({
    name: item.name,
    url: item.url,
    external: false,
  })),
  { name: 'RSS', url: '/atom.xml', external: false },
  ...(githubLink
    ? [
        {
          name: 'GitHub',
          url: githubLink.url,
          external: true,
        },
      ]
    : []),
]
---

<footer class="border-t border-black bg-black text-white dark:border-white/35">
  <div class="mx-auto flex w-full max-w-[96rem] flex-col justify-between gap-16 px-4 py-16 leading-relaxed sm:px-6 lg:flex-row lg:px-8 lg:py-24">
    <div class="flex w-full max-w-3xl flex-col gap-14">
      <div class="flex flex-col gap-7">
        <p class="max-w-[12ch] text-[2.25rem] leading-[0.98] tracking-[-0.055em] sm:text-[3.75rem]">
          Build a quieter corner of the internet.
        </p>
        <p class="max-w-[42rem] text-base text-white/68 sm:text-lg">
          {cleanDescription}
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
          <a
            href="/atom.xml"
            class="flex min-h-12 flex-1 items-center justify-between rounded-sm border border-white/20 bg-white px-4 py-3 text-base text-black no-underline transition-colors duration-150 hover:bg-[#f7f7f3]"
          >
            <span class="text-black/55">Subscribe via feed</span>
            <span class="font-medium">RSS</span>
          </a>

          <div class="group relative inline-block">
            <div class="absolute inset-0 z-[2] rounded-sm border border-black bg-[#f1f333]"></div>
            <div class="absolute inset-0 z-[1] rounded-sm border border-black bg-[#dc341e] transition-transform duration-150 group-hover:translate-x-2 group-hover:translate-y-2"></div>
            <a
              href={githubLink?.url ?? '/'}
              target={githubLink ? '_blank' : undefined}
              rel={githubLink ? 'noreferrer' : undefined}
              class="relative z-[3] inline-flex h-12 min-w-14 items-center justify-center rounded-sm border border-black bg-[#ff90e8] px-4 text-lg text-black no-underline transition-transform duration-150 group-hover:-translate-x-2 group-hover:-translate-y-2"
              aria-label="Open GitHub"
            >
              →
            </a>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 text-sm text-white/72">
        <span class="inline-flex size-7 items-center justify-center rounded-sm border border-white/20 bg-white p-1">
          <img src="/avatar.svg" alt="" class="themed-svg size-full object-contain" loading="lazy" decoding="async" />
        </span>
        <p>© {yearDisplay} {SITE.author}</p>
      </div>
    </div>

    <div class="flex w-full max-w-3xl flex-col gap-14">
      <div class="grid gap-12 sm:grid-cols-2">
        <div class="flex flex-col gap-4">
          <p class="text-sm uppercase tracking-[0.14em] text-white/45">Explore</p>
          <div class="flex flex-col gap-3 text-base">
            {primaryLinks.map((link) => (
              <a href={link.url} class="text-white no-underline transition-colors duration-150 hover:text-[#ff90e8]">
                {link.name}
              </a>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <p class="text-sm uppercase tracking-[0.14em] text-white/45">Elsewhere</p>
          <div class="flex flex-col gap-3 text-base">
            {secondaryLinks.map((link) => (
              <a
                href={link.url}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noreferrer' : undefined}
                class="text-white no-underline transition-colors duration-150 hover:text-[#ff90e8]"
              >
                {link.name}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-6">
        <p class="max-w-[30rem] text-sm text-white/52">
          Personal writing, selected projects, and notes on building software with less noise.
        </p>

        <div class="flex flex-wrap items-center gap-3">
          {SOCIAL_LINKS.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noreferrer"
              class="inline-flex size-11 items-center justify-center rounded-sm border border-white/18 text-white no-underline transition-all duration-150 hover:-translate-x-[2px] hover:-translate-y-[2px] hover:border-white hover:bg-white hover:text-black hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.18)]"
              aria-label={item.name}
            >
              <span class:list={[item.icon, 'text-[1.1rem]']}></span>
            </a>
          ))}

          <a
            href="/atom.xml"
            class="inline-flex size-11 items-center justify-center rounded-sm border border-white/18 text-white no-underline transition-all duration-150 hover:-translate-x-[2px] hover:-translate-y-[2px] hover:border-white hover:bg-white hover:text-black hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.18)]"
            aria-label="RSS"
          >
            <span class="icon-[ri--rss-line] text-[1.1rem]"></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
