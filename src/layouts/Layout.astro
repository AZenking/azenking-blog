---
import '~/styles/global.css'
import '~/styles/markdown.css'
import '~/styles/lqip.css'
import '~/styles/github-card.css'
import Analytics from '@vercel/analytics/astro'
import { SITE } from '~/config'
import Head from '~/components/base/Head.astro'
import Header from './Header.astro'
import Footer from './Footer.astro'

type Props = {
  title: string
  description: string
  image?: string
  ogType?: 'website' | 'article'
  publishedTime?: string
  modifiedTime?: string
  author?: string
  tags?: string[]
  fullWidth?: boolean
  hideFooter?: boolean
}

const {
  title,
  description,
  image,
  ogType,
  publishedTime,
  modifiedTime,
  author,
  tags,
  fullWidth = false,
  hideFooter = false,
}: Props = Astro.props
---

<!doctype html>
<html lang={SITE.lang} transition:name="root" transition:animate={SITE.transition ? 'fade' : 'none'}>
  <head>
    <Head title={`${title} | ${SITE.title}`} {description} {image} {ogType} {publishedTime} {modifiedTime} {author} {tags} />
  </head>
  <body class="flex flex-col">
    <Header />
    <div class="grow flex">
      <main class:list={['relative grow min-w-0', fullWidth ? 'w-full' : 'global-layout-width mx-auto']}>
        <slot />
        <Analytics />
      </main>
    </div>
    {!hideFooter && <Footer />}
  </body>
</html>
