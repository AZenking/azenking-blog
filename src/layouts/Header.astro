---
import { SITE } from '~/config'
import ThemeToggle from '~/components/theme/ThemeToggle'
import SearchSwitch from '~/components/base/SearchSwitch.astro'

const navLinks = [
  { name: '首页', url: '/' },
  { name: '文章', url: '/posts' },
  { name: '照片', url: '/photos' },
  { name: '朋友', url: '/friends' },
  { name: '分类', url: '/tags' },
  { name: '关于我', url: '/#about' },
]

const isLinkActive = (linkUrl: string, pathname: string) => {
  if (linkUrl.startsWith('/#')) return false
  if (linkUrl === '/') return pathname === '/'
  return pathname.startsWith(linkUrl)
}
---

<header class="apple-ui sticky top-0 z-50 border-b border-border/55 bg-background/78 backdrop-blur-xl supports-[backdrop-filter]:bg-background/62">
  <div class="global-layout-width mx-auto flex h-16 items-center gap-6 px-4 sm:h-[4.5rem] sm:px-6">
    <a
      href="/"
      class="text-[15px] font-medium tracking-[-0.02em] text-foreground/92 transition-colors hover:text-foreground"
      transition:persist
    >
      {SITE.author}
    </a>

    <nav class="ml-2 hidden items-center gap-0.5 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.url}
          class:list={[
            'rounded-full px-3 py-1.5 text-sm font-normal transition-colors',
            isLinkActive(link.url, Astro.url.pathname)
              ? 'bg-foreground text-background'
              : 'text-muted-foreground hover:bg-muted/55 hover:text-foreground',
          ]}
          aria-current={isLinkActive(link.url, Astro.url.pathname) ? 'page' : undefined}
        >
          {link.name}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-1.5 sm:gap-2" transition:persist="header-theme-toggle">
      <div class="hidden items-center justify-center rounded-full text-muted-foreground transition-colors hover:text-foreground sm:inline-flex">
        <SearchSwitch />
      </div>

      <div class="inline-flex size-8 items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-muted/55 hover:text-foreground">
        <ThemeToggle client:load />
      </div>
    </div>
  </div>

  <nav class="global-layout-width mx-auto flex items-center gap-1 overflow-x-auto px-4 pb-2 text-xs md:hidden sm:px-6">
    {navLinks.map((link) => (
      <a
        href={link.url}
        class:list={[
          'shrink-0 rounded-full px-3 py-1.5 font-normal transition-colors',
          isLinkActive(link.url, Astro.url.pathname)
            ? 'bg-foreground text-background'
            : 'text-muted-foreground hover:bg-muted/55 hover:text-foreground',
        ]}
        aria-current={isLinkActive(link.url, Astro.url.pathname) ? 'page' : undefined}
      >
        {link.name}
      </a>
    ))}
  </nav>
</header>
