---
import SearchSwitch from '~/components/base/SearchSwitch.astro'
import { HEADER_LINKS, SITE, SOCIAL_LINKS } from '~/config'

const isLinkActive = (linkUrl: string, pathname: string) => {
  if (linkUrl === '/') return pathname === '/'
  return pathname === linkUrl || pathname.startsWith(`${linkUrl}/`)
}

const githubLink = SOCIAL_LINKS.find((item) => item.name === 'github')
---

<header class="magi-header">
  <div class="magi-header-inner">
    <a href="/" class="magi-header-brand" aria-label={`${SITE.title} 首页`} transition:persist>
      <span class="magi-header-logo" aria-hidden="true">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Magi logo">
          <title>Magi</title>
          <path d="M8 8 L8 40" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
          <path d="M8 8 L22 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
          <path d="M8 24 L18 24" stroke="currentColor" stroke-width="2" stroke-linecap="square" opacity="0.45" />
          <path d="M8 40 L22 40" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
          <path d="M28 8 L34 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
          <path d="M40 8 L34 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
          <path d="M34 22 L34 40" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
          <line x1="22" y1="40" x2="34" y2="40" stroke="currentColor" stroke-width="1" stroke-linecap="square" opacity="0.2" />
        </svg>
      </span>
    </a>

    <nav class="magi-header-nav" aria-label="主导航">
      {
        HEADER_LINKS.map((link) => (
          <a
            href={link.url}
            class:list={[
              'magi-header-link',
              isLinkActive(link.url, Astro.url.pathname) ? 'is-active' : '',
            ]}
            aria-current={isLinkActive(link.url, Astro.url.pathname) ? 'page' : undefined}
          >
            {link.name}
          </a>
        ))
      }
    </nav>

    <div class="magi-header-actions" transition:persist="header-search-switch">
      <SearchSwitch labelClass="magi-header-search-label" />

      {githubLink && (
        <a
          href={githubLink.url}
          class="magi-header-icon magi-header-github"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
          title="GitHub"
        >
          <span class="icon-[ri--github-fill] magi-header-icon-glyph" aria-hidden="true"></span>
        </a>
      )}

      <button
        id="theme-toggle"
        class="magi-header-icon magi-header-theme-toggle"
        type="button"
        aria-label="切换主题"
        title="切换主题"
      >
        <span class="icon-[ri--sun-line] magi-header-icon-glyph magi-theme-icon-dark" aria-hidden="true"></span>
        <span class="icon-[ri--moon-line] magi-header-icon-glyph magi-theme-icon-light" aria-hidden="true"></span>
      </button>

      <button
        id="header-menu-button"
        class="magi-header-menu-button"
        type="button"
        aria-expanded="false"
        aria-controls="header-mobile-menu"
        aria-label="切换导航菜单"
      >
        <span data-header-line="top"></span>
        <span data-header-line="bottom"></span>
      </button>
    </div>
  </div>

  <div id="header-mobile-menu" class="magi-header-mobile-menu hidden">
    <nav aria-label="移动端导航">
      {
        HEADER_LINKS.map((link) => (
          <a
            href={link.url}
            class:list={[
              'magi-header-mobile-link',
              isLinkActive(link.url, Astro.url.pathname) ? 'is-active' : '',
            ]}
            aria-current={isLinkActive(link.url, Astro.url.pathname) ? 'page' : undefined}
          >
            {link.name}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .magi-header {
    position: relative;
    z-index: 20;
    padding: env(safe-area-inset-top) 1rem 0;
    color: var(--article-ink);
  }

  .magi-header-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(1rem, 2.4vw, 2.5rem);
    width: min(100%, calc(var(--content-width) + 4rem));
    min-height: 4.75rem;
    margin-inline: auto;
    padding: 0.85rem clamp(1rem, 2.5vw, 2rem);
    color: var(--article-ink);
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
  }

  .magi-header-brand {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    justify-self: start;
    gap: 0.85rem;
    color: var(--article-ink);
    text-decoration: none;
    transition:
      color 200ms ease,
      opacity 200ms ease;
  }

  .magi-header-brand:hover {
    color: var(--article-ink);
    opacity: 0.78;
  }

  .magi-header-logo {
    display: inline-grid;
    width: 2.25rem;
    height: 2.25rem;
    flex: 0 0 auto;
    place-items: center;
  }

  .magi-header-logo svg {
    display: block;
    width: 100%;
    height: 100%;
  }




  .magi-header-nav {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
  }

  @media (min-width: 860px) {
    .magi-header-nav { display: flex; }
  }

  .magi-header-link {
    display: inline-flex;
    min-height: 2.35rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 4px;
    padding-inline: clamp(0.75rem, 1.2vw, 1.05rem);
    color: var(--article-soft);
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.88;
    transition:
      background-color 200ms ease,
      border-color 200ms ease,
      color 200ms ease,
      opacity 200ms ease;
  }

  .magi-header-link:hover {
    border-color: var(--article-rule);
    background: light-dark(rgb(31 31 29 / 0.035), rgb(232 228 220 / 0.045));
    color: var(--article-ink);
    opacity: 1;
  }

  .magi-header-link.is-active {
    border-color: light-dark(rgb(31 31 29 / 0.14), rgb(232 228 220 / 0.14));
    background: light-dark(rgb(31 31 29 / 0.055), rgb(232 228 220 / 0.06));
    color: var(--brand);
    opacity: 1;
  }

  .magi-header-brand:focus-visible,
  .magi-header-link:focus-visible,
  .magi-header-icon:focus-visible,
  :global(.magi-header-search:focus-visible),
  .magi-header-menu-button:focus-visible,
  .magi-header-mobile-link:focus-visible {
    outline: 1px solid var(--brand);
    outline-offset: 0.35rem;
  }

  .magi-header-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    padding: 0;
    color: var(--article-soft);
    background: transparent;
    border: 1px solid var(--article-rule);
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color 200ms ease,
      border-color 200ms ease,
      color 200ms ease,
      opacity 200ms ease;
  }

  .magi-header-icon:hover {
    border-color: light-dark(rgb(31 31 29 / 0.22), rgb(232 228 220 / 0.24));
    background: light-dark(rgb(31 31 29 / 0.035), rgb(232 228 220 / 0.045));
    color: var(--article-ink);
  }

  .magi-header-icon-glyph {
    display: inline-block;
    width: 1em;
    height: 1em;
    font-size: 0.95rem;
    line-height: 1;
  }

  /* 主题图标根据 html 上的 .dark / .light 类切换显示 */
  .magi-theme-icon-light {
    display: none;
  }

  :global(html.dark) .magi-theme-icon-dark {
    display: inline-block;
  }

  :global(html.dark) .magi-theme-icon-light {
    display: none;
  }

  :global(html.light) .magi-theme-icon-dark {
    display: none;
  }

  :global(html.light) .magi-theme-icon-light {
    display: inline-block;
  }

  .magi-header-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    justify-self: end;
    gap: 0.55rem;
  }

  .magi-header-menu-button {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
    width: 2.35rem;
    height: 2.35rem;
    padding: 0;
    color: var(--article-soft);
    background: transparent;
    border: 1px solid var(--article-rule);
    border-radius: 4px;
    cursor: pointer;
    transition:
      background-color 200ms ease,
      border-color 200ms ease,
      color 200ms ease;
  }

  .magi-header-menu-button:hover {
    border-color: light-dark(rgb(31 31 29 / 0.22), rgb(232 228 220 / 0.24));
    background: light-dark(rgb(31 31 29 / 0.035), rgb(232 228 220 / 0.045));
    color: var(--article-ink);
  }

  @media (min-width: 860px) {
    .magi-header-menu-button { display: none; }
  }

  .magi-header-menu-button span {
    display: block;
    width: 0.95rem;
    height: 1px;
    background: currentColor;
    transition: transform 200ms ease;
  }

  .magi-header-mobile-menu {
    width: min(100%, calc(var(--content-width) + 4rem));
    margin-inline: auto;
    padding: 0.6rem clamp(1rem, 2.5vw, 2rem) 0;
  }

  @media (min-width: 860px) {
    .magi-header-mobile-menu { display: none !important; }
  }

  .magi-header-mobile-menu nav {
    overflow: hidden;
    border: 1px solid light-dark(rgb(31 31 29 / 0.08), rgb(232 228 220 / 0.1));
    border-radius: 0.35rem;
    background: light-dark(rgb(255 255 255 / 0.92), rgb(16 16 15 / 0.94));
    box-shadow: 0 12px 28px light-dark(rgb(31 31 29 / 0.06), rgb(0 0 0 / 0.18));
  }

  .magi-header-mobile-link {
    display: block;
    padding: 0.8rem 1rem;
    color: var(--article-soft);
    font-family: var(--font-geist-mono);
    font-size: 0.8125rem;
    text-decoration: none;
    border-block-end: 1px solid var(--article-rule);
    opacity: 0.72;
    transition:
      color 200ms ease,
      opacity 200ms ease;
  }

  .magi-header-mobile-link:hover,
  .magi-header-mobile-link.is-active {
    color: var(--brand);
    opacity: 1;
  }

  :global(.magi-header-search) {
    display: inline-flex;
    min-height: 2.35rem;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    border: 1px solid var(--article-rule);
    border-radius: 4px;
    padding-inline: 1rem;
    font-family: var(--font-geist-mono);
    font-size: 0.75rem;
    color: var(--article-soft);
    background: transparent;
    cursor: pointer;
    transition:
      background-color 200ms ease,
      border-color 200ms ease,
      color 200ms ease,
      opacity 200ms ease;
  }

  :global(.magi-header-search:hover) {
    border-color: light-dark(rgb(31 31 29 / 0.22), rgb(232 228 220 / 0.24));
    background: light-dark(rgb(31 31 29 / 0.035), rgb(232 228 220 / 0.045));
    color: var(--article-ink);
  }

  :global(.magi-header-search-label) {
    display: inline;
  }

  :global(.magi-header-search-icon) {
    width: 0.95rem;
    height: 0.95rem;
    flex: 0 0 auto;
  }

  @media (max-width: 859px) {
    .magi-header {
      padding-inline: 0.75rem;
    }

    .magi-header-inner {
      grid-template-columns: minmax(0, 1fr) auto;
      min-height: 4.25rem;
      padding: 0.7rem 0.85rem;
    }

    .magi-header-actions {
      gap: 0.35rem;
    }

    .magi-header-logo {
      width: 2rem;
      height: 2rem;
    }


    :global(.magi-header-search) {
      width: 2.35rem;
      min-width: 2.35rem;
      padding-inline: 0;
    }

    :global(.magi-header-search-label),
    :global(.magi-header-search .magi-header-search-label) {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (max-width: 420px) {
    .magi-header-brand {
      gap: 0.55rem;
    }

    .magi-header-logo {
      width: 1.75rem;
      height: 1.75rem;
    }

    .magi-header-icon,
    .magi-header-menu-button,
    :global(.magi-header-search) {
      width: 2.1rem;
      min-width: 2.1rem;
      height: 2.1rem;
      min-height: 2.1rem;
    }
  }
</style>

<script>
  const initHeaderMenu = () => {
    const menuButton = document.getElementById('header-menu-button')
    const mobileMenu = document.getElementById('header-mobile-menu')
    const topLine = document.querySelector('[data-header-line="top"]')
    const bottomLine = document.querySelector('[data-header-line="bottom"]')

    if (!menuButton || !mobileMenu) return

    const syncMenuState = (expanded: boolean) => {
      menuButton.setAttribute('aria-expanded', expanded ? 'true' : 'false')
      mobileMenu.classList.toggle('hidden', !expanded)
      topLine?.classList.toggle('-translate-y-[3px]', !expanded)
      topLine?.classList.toggle('translate-y-0', expanded)
      topLine?.classList.toggle('rotate-45', expanded)
      bottomLine?.classList.toggle('translate-y-[3px]', !expanded)
      bottomLine?.classList.toggle('translate-y-0', expanded)
      bottomLine?.classList.toggle('-rotate-45', expanded)
    }

    syncMenuState(false)

    menuButton.onclick = () => {
      const expanded = menuButton.getAttribute('aria-expanded') === 'true'
      syncMenuState(!expanded)
    }

    mobileMenu.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
      link.onclick = () => syncMenuState(false)
    })
  }

  initHeaderMenu()
  document.addEventListener('astro:page-load', initHeaderMenu)
</script>
