---
interface Props {
  title: string
  introduce: string
}

const { title, introduce } = Astro.props
---

<div class="apple-ui mx-auto max-w-3xl">
  <h1 class="text-[clamp(2.1rem,5vw,3.7rem)] font-semibold leading-[1.05] tracking-[-0.04em] text-foreground">{title}</h1>
  <p class="mt-5 max-w-[62ch] text-base leading-8 text-muted-foreground">{introduce}</p>
</div>
