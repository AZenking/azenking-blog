---
import type { Page } from 'astro'
import { POSTS_CONFIG } from '~/config'
import { cn } from '~/lib/utils'

interface Props {
  page: Page<any>
  baseUrl: string
  class?: string
}

const { page, class: className = '' } = Astro.props
---

<nav aria-label="Pagination" class={cn('mt-14 sm:mt-16 flex justify-center', className)}>
  <div class="inline-flex items-center gap-2 rounded-sm border border-black bg-white p-1.5 text-black sm:gap-3 sm:p-2 dark:border-white/35 dark:bg-black dark:text-white">
    <a
      href={page.url.prev}
      class={`inline-flex h-8 items-center gap-1 rounded-sm px-3 text-xs font-medium transition-all sm:h-9 sm:px-4 ${
        page.url.prev
          ? 'cursor-pointer border border-transparent hover:-translate-x-px hover:-translate-y-px hover:border-black hover:shadow-[2px_2px_0_0_#000] dark:hover:border-white/35 dark:hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]'
          : 'pointer-events-none cursor-not-allowed text-black/30 dark:text-white/30'
      }`}
    >
      <span class="icon-[ph--caret-left] size-3.5 sm:size-4"></span>
      <span class="hidden sm:inline">{POSTS_CONFIG.prevPageText}</span>
    </a>

    <p class="min-w-[6.5rem] text-center text-[11px] font-medium uppercase tracking-[0.12em] text-black/50 sm:min-w-[7rem] dark:text-white/50">
      {page.currentPage} / {page.lastPage}
    </p>

    <a
      href={page.url.next}
      class={`inline-flex h-8 items-center gap-1 rounded-sm px-3 text-xs font-medium transition-all sm:h-9 sm:px-4 ${
        page.url.next
          ? 'cursor-pointer border border-transparent hover:-translate-x-px hover:-translate-y-px hover:border-black hover:shadow-[2px_2px_0_0_#000] dark:hover:border-white/35 dark:hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]'
          : 'pointer-events-none cursor-not-allowed text-black/30 dark:text-white/30'
      }`}
    >
      <span class="hidden sm:inline">{POSTS_CONFIG.nextPageText}</span>
      <span class="icon-[ph--caret-right] size-3.5 sm:size-4"></span>
    </a>
  </div>
</nav>
