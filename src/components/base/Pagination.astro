---
import type { Page } from 'astro'
import { POSTS_CONFIG } from '~/config'
import { cn } from '~/lib/utils'

interface Props {
  page: Page<any>
  baseUrl: string
  class?: string
}

const { page, class: className = '' } = Astro.props
---

<nav aria-label="分页" class={cn('mt-14 sm:mt-16 flex justify-center', className)}>
  <div class="inline-flex items-center gap-2 border border-white/28 bg-[var(--theme-bg)] p-1.5 text-white sm:gap-3 sm:p-2">
    <a
      href={page.url.prev}
      class={`inline-flex min-h-11 items-center gap-1 px-3 font-mono text-xs font-semibold  transition-colors sm:px-4 ${
        page.url.prev
          ? 'cursor-pointer border border-transparent hover:border-[var(--theme-accent)] hover:bg-[var(--theme-accent)] hover:text-black'
          : 'pointer-events-none cursor-not-allowed text-white/30'
      }`}
    >
      <span class="icon-[ph--caret-left] size-3.5 sm:size-4"></span>
      <span class="hidden sm:inline">{POSTS_CONFIG.prevPageText}</span>
    </a>

    <p class="min-w-[6.5rem] text-center font-mono text-[11px] font-semibold  text-white/50 sm:min-w-[7rem]">
      {page.currentPage} / {page.lastPage}
    </p>

    <a
      href={page.url.next}
      class={`inline-flex min-h-11 items-center gap-1 px-3 font-mono text-xs font-semibold  transition-colors sm:px-4 ${
        page.url.next
          ? 'cursor-pointer border border-transparent hover:border-[var(--theme-accent)] hover:bg-[var(--theme-accent)] hover:text-black'
          : 'pointer-events-none cursor-not-allowed text-white/30'
      }`}
    >
      <span class="hidden sm:inline">{POSTS_CONFIG.nextPageText}</span>
      <span class="icon-[ph--caret-right] size-3.5 sm:size-4"></span>
    </a>
  </div>
</nav>
