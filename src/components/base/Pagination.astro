---
import type { Page } from 'astro'
import { POSTS_CONFIG } from '~/config'
import { cn } from '~/lib/utils'

interface Props {
  page: Page<any>
  baseUrl: string
  class?: string
}

const { page, class: className = '' } = Astro.props
---

<nav aria-label="Pagination" class={cn('mt-14 sm:mt-16 flex justify-center', className)}>
  <div class="apple-ui inline-flex items-center gap-2 rounded-full border border-border/55 bg-background/76 p-1.5 backdrop-blur-sm sm:gap-3 sm:p-2">
    <a
      href={page.url.prev}
      class={`inline-flex h-8 items-center gap-1 rounded-full px-3 text-xs font-medium transition-colors sm:h-9 sm:px-4 ${
        page.url.prev
          ? 'text-foreground/80 hover:bg-muted/55 hover:text-foreground cursor-pointer'
          : 'text-muted-foreground/38 pointer-events-none cursor-not-allowed'
      }`}
    >
      <span class="icon-[ph--caret-left] size-3.5 sm:size-4"></span>
      <span class="hidden sm:inline">{POSTS_CONFIG.prevPageText}</span>
    </a>

    <p class="min-w-[6.5rem] text-center text-[11px] font-medium uppercase tracking-[0.08em] text-muted-foreground sm:min-w-[7rem]">
      {page.currentPage} / {page.lastPage}
    </p>

    <a
      href={page.url.next}
      class={`inline-flex h-8 items-center gap-1 rounded-full px-3 text-xs font-medium transition-colors sm:h-9 sm:px-4 ${
        page.url.next
          ? 'text-foreground/80 hover:bg-muted/55 hover:text-foreground cursor-pointer'
          : 'text-muted-foreground/38 pointer-events-none cursor-not-allowed'
      }`}
    >
      <span class="hidden sm:inline">{POSTS_CONFIG.nextPageText}</span>
      <span class="icon-[ph--caret-right] size-3.5 sm:size-4"></span>
    </a>
  </div>
</nav>
