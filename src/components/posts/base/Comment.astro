---
import { COMMENT_CONFIG } from '~/config'
import Giscus from './Giscus.astro'

interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props

const enabled = COMMENT_CONFIG.enabled !== false && COMMENT_CONFIG.system !== 'none'

const giscusConfig = COMMENT_CONFIG.giscus
const giscusReady =
  COMMENT_CONFIG.system === 'giscus'
  && !!giscusConfig
  && !!giscusConfig.repoId
  && !!giscusConfig.categoryId
  && !giscusConfig.repoId.includes('HERE')

const renderGiscus = enabled && giscusReady
---

{renderGiscus && <Giscus id={id} title={title} />}
