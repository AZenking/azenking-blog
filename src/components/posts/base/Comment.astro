---
import { COMMENT_CONFIG } from '~/config'
import Gitalk from './Gitalk.astro'

interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props
const { enabled, system } = COMMENT_CONFIG

if (!enabled || system === 'none') {
  return null
}
---

<div class="comment-container">
  <div class="mb-6">
    <p class="fly-kicker">讨论</p>
    <h2 class="mt-2 text-[clamp(2rem,4vw,3.75rem)] font-black leading-[0.9] tracking-normal text-[var(--theme-text)]">
      评论
    </h2>
  </div>

  {system === 'gitalk' && <Gitalk id={id} title={title} />}
</div>
