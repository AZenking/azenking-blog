---
import { COMMENT_CONFIG } from '~/config'
import Gitalk from './Gitalk.astro'

interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props

const enabled = COMMENT_CONFIG.enabled !== false && COMMENT_CONFIG.system !== 'none'

const gitalkConfig = COMMENT_CONFIG.gitalk
const gitalkReady =
  COMMENT_CONFIG.system === 'gitalk'
  && !!gitalkConfig
  && !!gitalkConfig.clientID
  && !!gitalkConfig.clientSecret

const renderGitalk = enabled && gitalkReady
---

{renderGitalk && <Gitalk id={id} title={title} />}
