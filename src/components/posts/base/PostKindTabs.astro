---
interface Props {
  active: 'posts' | 'notes'
  class?: string
}

const { active, class: className = '' } = Astro.props

const tabs = [
  { key: 'posts', label: 'Posts', href: '/posts' },
  { key: 'notes', label: 'Notes', href: '/notes' },
] as const
---

<nav
  class:list={['apple-ui inline-flex items-center rounded-full border border-border/55 bg-background/76 p-1.5 backdrop-blur-sm', className]}
  aria-label="Content type switch"
>
  {
    tabs.map((tab) => {
      const isActive = active === tab.key
      return (
        <a
          href={tab.href}
          class:list={[
            'inline-flex items-center rounded-full px-[1.125rem] py-2 text-sm font-normal transition-colors',
            isActive ? 'bg-foreground text-background' : 'text-muted-foreground hover:bg-muted/55 hover:text-foreground',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          {tab.label}
        </a>
      )
    })
  }
</nav>
