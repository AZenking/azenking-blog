---
interface Props {
  active: 'posts' | 'notes'
  class?: string
}

const { active, class: className = '' } = Astro.props

const tabs = [
  { key: 'posts', label: '文章', href: '/posts' },
  { key: 'notes', label: '笔记', href: '/notes' },
] as const
---

<nav
  class:list={[
    'inline-flex items-center rounded-full border border-white/35 bg-[var(--theme-bg)] p-1 text-white',
    className,
  ]}
  aria-label="内容类型切换"
>
  {
    tabs.map((tab) => {
      const isActive = active === tab.key
      return (
        <a
          href={tab.href}
          class:list={[
            'inline-flex min-h-11 items-center rounded-full px-[1.125rem] py-2 font-mono text-xs font-semibold uppercase tracking-[0.12em] transition-colors',
            isActive
              ? 'bg-[var(--theme-accent)] text-black'
              : 'text-white/62 hover:bg-[var(--theme-surface-soft)] hover:text-[var(--theme-highlight)]',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          {tab.label}
        </a>
      )
    })
  }
</nav>
