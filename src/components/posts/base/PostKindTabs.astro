---
interface Props {
  active: 'posts' | 'notes'
  class?: string
}

const { active, class: className = '' } = Astro.props

const tabs = [
  { key: 'posts', label: 'Posts', href: '/posts' },
  { key: 'notes', label: 'Notes', href: '/notes' },
] as const
---

<nav
  class:list={[
    'inline-flex items-center rounded-sm border border-black bg-white p-1 text-black dark:border-white/35 dark:bg-black dark:text-white',
    className,
  ]}
  aria-label="Content type switch"
>
  {
    tabs.map((tab) => {
      const isActive = active === tab.key
      return (
        <a
          href={tab.href}
          class:list={[
            'inline-flex items-center rounded-sm px-[1.125rem] py-2 text-sm font-normal transition-all',
            isActive
              ? 'bg-black text-white dark:bg-white dark:text-black'
              : 'text-black/58 hover:-translate-x-px hover:-translate-y-px hover:bg-[#ece9df] hover:shadow-[2px_2px_0_0_#000] dark:text-white/58 dark:hover:bg-[#1d1d1b] dark:hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          {tab.label}
        </a>
      )
    })
  }
</nav>
