---
import LqipImage from '~/components/base/LqipImage.astro'
import { formatDate } from '~/lib/utils'
import { POSTS_CONFIG } from '~/config'
import Badge from '~/components/posts/base/Badge.astro'
import type { CardProps } from './List.astro'

interface Props extends CardProps {}

const { post, coverLayout, class: className, style }: Props = Astro.props

// 固定图片尺寸为 1200*630，宽高比约为 1.9:1
const IMAGE_WIDTH = 1200
const IMAGE_HEIGHT = 630

const imagePosition = post.data.coverLayout || coverLayout || 'left'
const isReverse = imagePosition === 'right'
const displayDate = post.data.updatedDate || post.data.pubDate
const visibleTags = post.data.tags?.slice(0, 3) ?? []
const recommendText = POSTS_CONFIG.recommendText
---

<article class:list={['group flex flex-col gap-8 py-1 md:flex-row md:items-start md:gap-12', isReverse ? 'md:flex-row-reverse' : '', className]} {style}>
  <a href={`/posts/${post.id}`} class="post-media block md:w-[20.5rem] md:shrink-0">
    <div class="aspect-[1200/630] overflow-hidden rounded-[1.35rem] border border-border/55 bg-muted/20">
      <div class="relative h-full w-full transition-transform duration-500 group-hover:scale-[1.015]">
        {
          post.data.cover && (
            <LqipImage
              src={post.data.cover}
              alt=""
              width={IMAGE_WIDTH}
              height={IMAGE_HEIGHT}
              loading="lazy"
              decoding="async"
              format="webp"
              class="h-full w-full object-cover"
            />
          )
        }
      </div>
    </div>
  </a>

  <div class="post-body flex min-w-0 flex-1 flex-col">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[0.68rem] font-medium uppercase tracking-[0.1em] text-muted-foreground/78">
      <time datetime={displayDate.toISOString()} class="inline-flex items-center gap-1.5">
        <span class="icon-[ph--calendar-blank] size-3.5"></span>
        {formatDate(displayDate)}
      </time>

      {
        post.data.updatedDate && (
          <time datetime={post.data.updatedDate.toISOString()} class="inline-flex items-center gap-1.5">
            <span class="icon-[ph--clock-clockwise] size-3.5" />
            {formatDate(post.data.updatedDate)}
          </time>
        )
      }
    </div>

    <a href={`/posts/${post.id}`} class="mt-4 block group/title">
      <h2 class="text-[clamp(1.35rem,2.4vw,1.75rem)] font-semibold leading-[1.24] tracking-[-0.022em] text-foreground transition-colors group-hover/title:text-foreground/78">
        {post.data.title}
      </h2>
      {post.data.description && <p class="mt-4 max-w-[45ch] line-clamp-3 text-[15px] leading-8 text-muted-foreground/85">{post.data.description}</p>}
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2.5">
      {
        post.data.recommend && (
          <span class="inline-flex items-center rounded-full border border-border/65 bg-muted/30 px-2.5 py-1 text-[11px] font-medium tracking-[0.1em] text-muted-foreground">
            {recommendText}
          </span>
        )
      }

      {visibleTags.map((tag) => <Badge type="tag" content={tag} variant="outline" showIcon={false} class="rounded-full border-border/60 bg-background/75" />)}
    </div>

    <a
      href={`/posts/${post.id}`}
      class="group/read mt-8 inline-flex items-center gap-1.5 text-sm font-medium text-foreground/72 transition-colors hover:text-foreground"
    >
      <span>{POSTS_CONFIG.readMoreText}</span>
      <span class="icon-[ph--arrow-right] size-4 transition-transform group-hover/read:translate-x-0.5"></span>
    </a>
  </div>
</article>
